---
import fs from "node:fs";
import path from "node:path";
import "../styles/global.css";
import ClarityDemo from "../components/ClarityDemo.astro";
import CourseCTA from "../components/CourseCTA.astro";
import Faq from "../components/Faq.astro";
import BeforeAfter from "../components/BeforeAfter.astro";
import Hero from "../components/Hero.astro";
import InteractiveCopy from "../components/InteractiveCopy.astro";
import ExecutiveModules from "../components/ExecutiveModules.astro";
import PromoBanner from "../components/PromoBanner.astro";
import SafetyCheck from "../components/SafetyCheck.astro";
import MemeMoment from "../components/MemeMoment.astro";
import PromptAnatomy from "../components/PromptAnatomy.astro";
import PromptLibrary from "../components/PromptLibrary.astro";
import RoiPath from "../components/RoiPath.astro";
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";
import { APP_VERSION } from "../constants/appVersion";
import { LEADER_PAGE_DATE_MODIFIED, LEADER_PAGE_DATE_PUBLISHED } from "../constants/pageSeo";
import {
  PROMPT_ANATOMY_PRIVACY_URL,
  PROMPT_ANATOMY_TERMS_URL,
  buildPromptAnatomyUrl,
  buildTelegramUrl,
} from "../constants/outboundLinks";
import { showLanguageSwitcher } from "../constants/siteLocale";
import { buildClientCopyPayload } from "../utils/clientCopyPayload";
import { buildLeaderPageJsonLd } from "../utils/pageJsonLd";

/**
 * Meme images use `uiCopy[lang].memes.items` indices 3, 0, 2, 5 (see `Page.astro` order).
 * Image `alt` text is `uiCopy[lang].memes.sequenceImageAlts[0..3]` in that same order (localized).
 * Post–ClarityDemo beat: index 5 → reward_2.png (printable kit / structure on desk).
 *
 * Live order is documented in `docs/VISUAL_CONTENT_MAP.md`.
 */
interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const copy = uiCopy[lang];
const meta = copy.meta;

const site = Astro.site?.toString().replace(/\/$/, "") ?? "https://ditreneris.github.io";
const baseUrl = `${site}${import.meta.env.BASE_URL}`;
const originBase = baseUrl.replace(/\/$/, "");
const localeCanonical = `${originBase}/${lang}/`;
const enCanonical = `${originBase}/en/`;
const ltCanonical = `${originBase}/lt/`;
const bilingualShipped = showLanguageSwitcher();

const ogLtPath = path.join(process.cwd(), "public", "og-image-lt.png");
const langTag = lang as string;
const ogImageFile = langTag === "lt" && fs.existsSync(ogLtPath) ? "og-image-lt.png" : "og-image.png";
const socialImageUrl = new URL(ogImageFile, baseUrl).toString();

const ogLocale = langTag === "lt" ? "lt_LT" : "en_US";
const ogLocaleAlternate = langTag === "lt" ? "en_US" : "lt_LT";

const base = import.meta.env.BASE_URL;
const faviconSvg = `${base}favicon.svg`;
const favicon32 = `${base}favicon-32x32.png`;
const favicon16 = `${base}favicon-16x16.png`;
const appleTouchIcon = `${base}apple-touch-icon.png`;
const manifestUrl = `${base}site.webmanifest`;
const serializedCopy = JSON.stringify(buildClientCopyPayload(copy)).replace(/</g, "\\u003c");
const footerCopy = copy.footer;

const structuredData = buildLeaderPageJsonLd({
  lang,
  localeCanonical,
  socialImageUrl,
  meta,
  faqItems: copy.faq.items,
});
const serializedJsonLd = JSON.stringify(structuredData).replace(/</g, "\\u003c");

/** Matches MemeMoment order (indices 3, 0, 2, 5); desktop `side` alternates left / right / left / right. */
const memeSequenceAlts = copy.memes.sequenceImageAlts;

const promptAnatomyFooterHref = buildPromptAnatomyUrl({ medium: "footer", campaign: "brand" });
const telegramHref = buildTelegramUrl();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={meta.description} />
    <link rel="canonical" href={localeCanonical} />
    <link rel="alternate" hreflang="en" href={enCanonical} />
    {bilingualShipped && <link rel="alternate" hreflang="lt" href={ltCanonical} />}
    <link rel="alternate" hreflang="x-default" href={enCanonical} />
    <link rel="icon" type="image/svg+xml" href={faviconSvg} />
    <link rel="icon" type="image/png" sizes="32x32" href={favicon32} />
    <link rel="icon" type="image/png" sizes="16x16" href={favicon16} />
    <link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon} />
    <link rel="manifest" href={manifestUrl} />
    <meta property="og:site_name" content="Prompt Anatomy" />
    <meta property="og:title" content={meta.title} />
    <meta property="og:description" content={meta.description} />
    <meta property="og:type" content="website" />
    <meta property="article:published_time" content={LEADER_PAGE_DATE_PUBLISHED} />
    <meta property="article:modified_time" content={LEADER_PAGE_DATE_MODIFIED} />
    <meta property="og:url" content={localeCanonical} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={meta.socialImageAlt} />
    <meta property="og:locale" content={ogLocale} />
    {bilingualShipped && <meta property="og:locale:alternate" content={ogLocaleAlternate} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={meta.title} />
    <meta name="twitter:description" content={meta.description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={meta.socialImageAlt} />
    <meta name="theme-color" content="#0b1320" />
    <meta name="generator" content={`PromptAnatomy Executive OS ${APP_VERSION}`} />
    <title>{meta.title}</title>
    <script is:inline type="application/ld+json" set:html={serializedJsonLd} />
    <script is:inline set:html={`window.__PA_COPY__ = ${serializedCopy};`} />
  </head>
  <body id="top">
    <a href="#ctx-company" class="skip-link focus-ring">{copy.a11y.skipLink}</a>
    <Hero lang={lang} />
    <main>
      <MemeMoment
        lang={lang}
        index={3}
        src="meme-03-clear-decision.png"
        alt={memeSequenceAlts[0]}
        accent="gold"
        side="left"
        width={1280}
        height={720}
        loading="eager"
        fetchPriority="high"
      />
      <BeforeAfter lang={lang} />
      <MemeMoment
        lang={lang}
        index={0}
        src="meme-01-ai-chaos.png"
        alt={memeSequenceAlts[1]}
        accent="gold"
        side="right"
        width={1280}
        height={720}
      />
      <ExecutiveModules lang={lang} />
      <PromoBanner lang={lang} />
      <MemeMoment
        lang={lang}
        index={2}
        src="meme-04-delegation-bottleneck.png"
        alt={memeSequenceAlts[2]}
        accent="gold"
        side="left"
        width={1280}
        height={720}
      />
      <ClarityDemo lang={lang} />
      <MemeMoment
        lang={lang}
        index={5}
        src="reward_2.png"
        alt={memeSequenceAlts[3]}
        accent="gold"
        side="right"
        width={1280}
        height={720}
      />
      <SafetyCheck lang={lang} />
      <CourseCTA lang={lang} />
      <PromptAnatomy lang={lang} />
      <RoiPath lang={lang} />
      <Faq lang={lang} />
      <PromptLibrary lang={lang} />
    </main>
    <footer class="mx-auto flex max-w-7xl flex-col gap-4 border-t border-white/5 px-5 pb-10 pt-8 text-sm text-slate-500 sm:px-8 md:flex-row md:items-center md:justify-between">
      <div class="flex flex-col gap-1">
        <p class="font-semibold text-slate-300">
          {footerCopy.brand}
          <span aria-hidden="true" class="mx-2 text-slate-600">·</span>
          <a
            href={promptAnatomyFooterHref}
            class="focus-ring text-brand-accent transition hover:text-brand-accent-hover"
          >
            promptanatomy.app
          </a>
        </p>
        <p>
          {footerCopy.tagline}
          <span aria-hidden="true" class="mx-2 text-slate-700">·</span>
          <span
            class="tabular-nums text-slate-600"
            aria-label={`${copy.footer.versionAria} ${APP_VERSION}`}>v{APP_VERSION}</span
          >
        </p>
      </div>
      <nav class="flex flex-wrap items-center gap-4" aria-label={copy.a11y.footerLegalNavAria}>
        <a
          href={telegramHref}
          target="_blank"
          rel="noopener noreferrer"
          class="focus-ring transition hover:text-slate-200"
        >
          {footerCopy.telegram}
        </a>
        <a
          href={PROMPT_ANATOMY_PRIVACY_URL}
          class="focus-ring transition hover:text-slate-200"
        >
          {footerCopy.privacy}
        </a>
        <a
          href={PROMPT_ANATOMY_TERMS_URL}
          class="focus-ring transition hover:text-slate-200"
        >
          {footerCopy.terms}
        </a>
      </nav>
    </footer>
    <p
      class="safe-bottom pointer-events-none fixed bottom-4 left-1/2 z-[100] hidden max-w-md -translate-x-1/2 rounded-xl border border-amber-400/40 bg-slate-950/95 px-4 py-3 text-center text-xs font-medium text-amber-100 shadow-lg backdrop-blur-sm"
      data-copy-manual-hint
      role="status"
      aria-live="polite"
    ></p>
    <InteractiveCopy />
    <script is:inline>
      (() => {
        const focusHashTarget = () => {
          const hashdecode = decodeURIComponent(location.hash || "");
          if (!hashdecode || hashdecode === "#") return;
          const el = document.querySelector(hashdecode);
          if (el instanceof HTMLElement) el.focus({ preventScroll: true });
        };
        document.addEventListener("DOMContentLoaded", focusHashTarget);
        window.addEventListener("hashchange", focusHashTarget);
      })();
    </script>
  </body>
</html>
