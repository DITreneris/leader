---
import { showLanguageSwitcher } from "../constants/siteLocale";

const site = Astro.site?.toString().replace(/\/$/, "") ?? "https://ditreneris.github.io";
const base = import.meta.env.BASE_URL;
const originBase = `${site}${base.replace(/\/$/, "")}`;
const enUrl = `${originBase}/en/`;
const ltUrl = `${originBase}/lt/`;
const bilingualShippedRoot = showLanguageSwitcher();
const rootUrl = `${originBase}/`;
const socialImageUrl = `${originBase}/og-image.png`;
const rootTitle = "CEO/COO Executive Prompt Operating Kit | Prompt Anatomy";
const rootDescription =
  "Standardize leadership AI briefs to a decision-ready shape in about a week. Static kit + demo—paste into ChatGPT, Claude, or Gemini, no login.";
const fbAppId = import.meta.env.PUBLIC_FB_APP_ID?.trim();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={rootDescription} />
    <meta property="og:site_name" content="Prompt Anatomy" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={rootUrl} />
    <meta property="og:title" content={rootTitle} />
    <meta property="og:description" content={rootDescription} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {fbAppId && <meta property="fb:app_id" content={fbAppId} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={rootTitle} />
    <meta name="twitter:description" content={rootDescription} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta http-equiv="refresh" content="0; url=./en/" />
    <link rel="canonical" href={enUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    {bilingualShippedRoot && <link rel="alternate" hreflang="lt" href={ltUrl} />}
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <title>Redirecting…</title>
    <script is:inline>
      location.replace("./en/");
    </script>
  </head>
  <body></body>
</html>
