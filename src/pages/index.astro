---
import { showLanguageSwitcher } from "../constants/siteLocale";

const site = Astro.site?.toString().replace(/\/$/, "") ?? "https://ditreneris.github.io";
const base = import.meta.env.BASE_URL;
const originBase = `${site}${base.replace(/\/$/, "")}`;
const enUrl = `${originBase}/en/`;
const ltUrl = `${originBase}/lt/`;
const bilingualShippedRoot = showLanguageSwitcher();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta http-equiv="refresh" content="0; url=./en/" />
    <link rel="canonical" href={enUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    {bilingualShippedRoot && <link rel="alternate" hreflang="lt" href={ltUrl} />}
    <link rel="alternate" hreflang="x-default" href={enUrl} />
    <title>Redirecting…</title>
    <script is:inline>
      location.replace("./en/");
    </script>
  </head>
  <body></body>
</html>
