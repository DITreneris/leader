---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const { faq } = uiCopy[lang];
---

<section id="faq" class="section-y mx-auto max-w-7xl px-5 sm:px-8" aria-labelledby="faq-heading">
  <div class="mx-auto max-w-2xl">
    <h2 id="faq-heading" class="text-center text-2xl font-black tracking-tight text-white sm:text-3xl">
      {faq.sectionTitle}
    </h2>
    <div class="mt-8 space-y-2">
      {
        faq.items.map((item) => (
          <details class="glass-card radius-lg px-4 py-0 sm:px-5">
            <summary class="focus-ring summary-hover cursor-pointer list-none py-3.5 text-left text-sm font-bold text-white outline-none sm:text-base [&::-webkit-details-marker]:hidden">
              {item.q}
            </summary>
            <div class="border-t border-white/10 pb-3.5 pt-2 text-sm leading-relaxed">
              {item.bullets?.length ? (
                <>
                  <p class="text-slate-300">{item.a}</p>
                  <ul class="mt-2 list-disc space-y-1.5 pl-5 text-slate-400">
                    {item.bullets.map((line) => (
                      <li>{line}</li>
                    ))}
                  </ul>
                </>
              ) : (
                <p class="text-slate-400">{item.a}</p>
              )}
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>
