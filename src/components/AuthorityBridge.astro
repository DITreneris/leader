---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const authority = uiCopy[lang].authority;
const motherHref = "https://www.promptanatomy.app/?utm_source=leader&utm_medium=bridge&utm_campaign=mother";
const sisterHref = "https://ditreneris.github.io/ceo/?utm_source=leader&utm_medium=bridge&utm_campaign=sister";
---

<section id="bridge" class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-bold uppercase tracking-[0.28em] text-brand-accent">
      {authority.eyebrow}
    </p>
    <h2 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl">
      {authority.title}
    </h2>
  </div>

  <div class="mt-10 grid gap-5 md:grid-cols-2">
    <a
      href={motherHref}
      class="focus-ring glass-card group relative block overflow-hidden rounded-[2rem] border border-brand-accent/40 p-6 transition motion-safe:hover:-translate-y-1 motion-safe:hover:border-brand-accent-hover/70"
    >
      <div class="pointer-events-none absolute -right-20 -top-20 h-56 w-56 rounded-full bg-brand-accent/15 blur-3xl"></div>
      <div class="relative flex items-center gap-3">
        <span class="logo-tile logo-glow flex h-10 w-10 items-center justify-center rounded-2xl ring-1 ring-white/10">
          <svg viewBox="0 0 32 32" aria-hidden="true" class="h-6 w-6">
            <path
              fill="#fbd304"
              transform="translate(4 3)"
              d="M13.5 1.5 4.5 14.25h6L8.25 22.5 19.5 9.75h-6L13.5 1.5z"
            />
          </svg>
        </span>
        <span class="rounded-full border border-brand-accent/40 bg-brand-accent/15 px-3 py-1 text-[10px] font-black uppercase tracking-[0.22em] text-brand-accent-hover">
          {authority.mother}
        </span>
      </div>
      <h3 class="relative mt-5 text-2xl font-black text-white">PromptAnatomy.app</h3>
      <p class="relative mt-4 leading-7 text-slate-300">
        {authority.motherText}
      </p>
    </a>

    <a
      href={sisterHref}
      class="focus-ring glass-card relative block rounded-[2rem] p-6 transition motion-safe:hover:-translate-y-1 motion-safe:hover:border-brand-accent/40"
    >
      <p class="text-[10px] font-black uppercase tracking-[0.22em] text-slate-400">
        {authority.sister}
      </p>
      <h3 class="mt-4 text-2xl font-black text-white">{authority.sisterTitle}</h3>
      <p class="mt-4 leading-7 text-slate-300">
        {authority.sisterText}
      </p>
    </a>
  </div>
</section>
