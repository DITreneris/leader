---
import SectionHeader from "./SectionHeader.astro";
import { buildCeoBridgeUrl, buildPromptAnatomyUrl } from "../constants/outboundLinks";
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const authority = uiCopy[lang].authority;
const motherHref = buildPromptAnatomyUrl({ medium: "bridge", campaign: "mother" });
const sisterHref = buildCeoBridgeUrl();
---

<section id="bridge" class="section-y mx-auto max-w-7xl px-5 sm:px-8">
  <SectionHeader eyebrow={authority.eyebrow} title={authority.title} eyebrowTone="promo" />
  <p class="mx-auto mt-4 max-w-3xl text-center text-sm text-slate-400">{authority.chooseNext}</p>

  <div class="mx-auto mt-10 max-w-3xl space-y-6">
    <a
      href={motherHref}
      target="_blank"
      rel="noopener noreferrer"
      class="focus-ring glass-card radius-xl group relative block overflow-hidden border border-brand-accent/40 p-8 transition motion-safe:hover:-translate-y-1 motion-safe:hover:border-brand-accent-hover/70"
    >
      <div class="pointer-events-none absolute -right-20 -top-20 h-56 w-56 rounded-full bg-brand-accent/15 blur-3xl"></div>
      <div class="relative flex items-center gap-3">
        <span class="logo-tile logo-glow flex h-10 w-10 items-center justify-center rounded-2xl ring-1 ring-white/10">
          <svg viewBox="0 0 32 32" aria-hidden="true" class="h-6 w-6">
            <path
              fill="#fbd304"
              transform="translate(4 3)"
              d="M13.5 1.5 4.5 14.25h6L8.25 22.5 19.5 9.75h-6L13.5 1.5z"
            />
          </svg>
        </span>
        <span class="type-micro-label rounded-full border border-brand-accent/40 bg-brand-accent/15 px-3 py-1 text-brand-accent-hover">
          {authority.mother}
        </span>
      </div>
      <h3 class="relative mt-5 text-2xl font-black text-white">PromptAnatomy.app</h3>
      <p class="relative mt-4 leading-7 text-slate-300">
        {authority.motherText}
      </p>
    </a>

    <p class="text-center text-sm leading-6 text-slate-400">
      <span class="font-semibold text-slate-300">{authority.sisterEyebrow}:</span>
      {" "}
      {authority.sisterText}{" "}
      <a
        href={sisterHref}
        target="_blank"
        rel="noopener noreferrer"
        class="focus-ring font-semibold text-brand-accent transition hover:text-brand-accent-hover"
      >
        {authority.sisterLink}
      </a>
    </p>
  </div>
</section>
