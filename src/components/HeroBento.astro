---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const c = uiCopy[lang];
const v = c.heroBento;

const rowBase =
  "flex min-h-[3.75rem] flex-1 items-center gap-4 border border-white/[0.08] bg-white/[0.04] py-3.5 pl-4 pr-4 shadow-none radius-sm";
---

<aside class="glass-card radius-xl relative overflow-hidden p-6 sm:p-8" aria-label={v.ariaLabel}>
  <div
    class="pointer-events-none absolute -right-20 -top-20 h-72 w-72 rounded-full bg-brand-accent/10 blur-3xl"
    aria-hidden="true"
  >
  </div>

  <div class="relative">
    <p class="type-micro-label mb-5 text-center text-slate-400 sm:text-left">
      {v.panelOverline}
    </p>

    <ol class="m-0 flex list-none flex-col gap-3 p-0" aria-label={v.tilesAriaLabel}>
      <li class="flex gap-3" aria-posinset={1} aria-setsize={3}>
        <span
          class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-white/12 bg-white/[0.03] text-[11px] font-black tabular-nums text-slate-400"
          aria-hidden="true"
        >
          1
        </span>
        <article class:list={[rowBase, "border-l-4 border-l-[var(--color-brand-accent)]"]}>
          <span
            class="grid h-11 w-11 shrink-0 place-items-center radius-sm bg-brand-accent/15 text-brand-accent-hover"
            aria-hidden="true"
          >
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9"></circle>
              <circle cx="12" cy="12" r="5"></circle>
              <circle cx="12" cy="12" r="1.6" fill="currentColor" stroke="none"></circle>
            </svg>
          </span>
          <span class="min-w-0 text-base font-black tracking-tight text-white">{v.tileDecision}</span>
        </article>
      </li>

      <li class="flex gap-3" aria-posinset={2} aria-setsize={3}>
        <span
          class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-white/12 bg-white/[0.03] text-[11px] font-black tabular-nums text-slate-400"
          aria-hidden="true"
        >
          2
        </span>
        <article class:list={[rowBase, "border-l-4 border-l-rose-400/70"]}>
          <span
            class="grid h-11 w-11 shrink-0 place-items-center radius-sm bg-rose-400/15 text-rose-100"
            aria-hidden="true"
          >
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3 4 6v6.5c0 4.6 3.5 7.5 8 8.5 4.5-1 8-3.9 8-8.5V6l-8-3z"></path>
              <path d="M12 8.5v4.5"></path>
              <path d="M12 16.2v.1"></path>
            </svg>
          </span>
          <span class="min-w-0 text-base font-black tracking-tight text-white">{v.tileRisks}</span>
        </article>
      </li>

      <li class="flex gap-3" aria-posinset={3} aria-setsize={3}>
        <span
          class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-white/12 bg-white/[0.03] text-[11px] font-black tabular-nums text-slate-400"
          aria-hidden="true"
        >
          3
        </span>
        <article class:list={[rowBase, "border-l-4 border-l-emerald-400/70"]}>
          <span
            class="grid h-11 w-11 shrink-0 place-items-center radius-sm bg-emerald-400/15 text-emerald-100"
            aria-hidden="true"
          >
            <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 3 4 14h6l-1 7 9-11h-6l1-7z"></path>
            </svg>
          </span>
          <span class="min-w-0 text-base font-black tracking-tight text-white">{v.tileNextAction}</span>
        </article>
      </li>
    </ol>
  </div>
</aside>
