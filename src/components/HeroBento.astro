---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const c = uiCopy[lang];
const v = c.heroBento;
---

<aside class="glass-card relative overflow-hidden rounded-[2rem] p-6 sm:p-8" aria-label={v.ariaLabel}>
  <div class="pointer-events-none absolute -right-24 -top-24 h-80 w-80 rounded-full bg-brand-accent/15 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-24 -left-24 h-80 w-80 rounded-full bg-white/5 blur-3xl"></div>

  <div class="relative">
    <div class="flex flex-wrap items-center gap-2">
      <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-200">
        {v.chipOne}
      </span>
      <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-200">
        {v.chipTwo}
      </span>
      <span class="rounded-full border border-brand-accent/30 bg-brand-accent/15 px-3 py-1.5 text-[10px] font-black uppercase tracking-[0.18em] text-brand-accent-hover">
        {v.chipThree}
      </span>
    </div>

    <h2 class="mt-6 text-2xl font-black leading-tight tracking-tight text-white sm:text-3xl">
      {v.title}
    </h2>

    <ol
      class="mt-6 flex flex-wrap items-center gap-x-2 gap-y-2 text-[10px] font-black uppercase tracking-[0.2em] text-slate-300"
      aria-label={v.flowAriaLabel}
    >
      <li class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5">{v.flowContext}</li>
      <li aria-hidden="true" class="text-slate-600">→</li>
      <li class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5">{v.flowModule}</li>
      <li aria-hidden="true" class="text-slate-600">→</li>
      <li class="rounded-full border border-brand-accent/40 bg-brand-accent/15 px-3 py-1.5 text-brand-accent-hover">
        {v.flowBrief}
      </li>
      <li aria-hidden="true" class="text-slate-600">→</li>
      <li class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5">{v.flowSafety}</li>
    </ol>

    <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2" role="list" aria-label={v.tilesAriaLabel}>
      <article role="listitem" class="surface-accent accent-glow flex items-center gap-4 rounded-3xl p-5 ring-1 ring-brand-accent/30">
        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-brand-accent/20 text-brand-accent-hover" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="9" />
            <circle cx="12" cy="12" r="5" />
            <circle cx="12" cy="12" r="1.6" fill="currentColor" stroke="none" />
          </svg>
        </span>
        <span class="text-base font-black tracking-tight text-white">{v.tileDecision}</span>
      </article>

      <article role="listitem" class="surface-panel flex items-center gap-4 rounded-3xl p-5 ring-1 ring-white/5">
        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-white/[0.06] text-slate-200" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="8.5" r="3.6" />
            <path d="M4.5 19.5c1.6-3.4 4.6-5 7.5-5s5.9 1.6 7.5 5" />
          </svg>
        </span>
        <span class="text-base font-black tracking-tight text-white">{v.tileOwner}</span>
      </article>

      <article role="listitem" class="surface-panel flex items-center gap-4 rounded-3xl p-5 ring-1 ring-white/5">
        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-white/[0.06] text-slate-200" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="8.5" />
            <path d="M12 7.5v5l3 2" />
          </svg>
        </span>
        <span class="text-base font-black tracking-tight text-white">{v.tileDeadline}</span>
      </article>

      <article role="listitem" class="flex items-center gap-4 rounded-3xl bg-rose-300/10 p-5 ring-1 ring-rose-200/20">
        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-rose-300/15 text-rose-100" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3 4 6v6.5c0 4.6 3.5 7.5 8 8.5 4.5-1 8-3.9 8-8.5V6l-8-3z" />
            <path d="M12 8.5v4.5" />
            <path d="M12 16.2v.1" />
          </svg>
        </span>
        <span class="text-base font-black tracking-tight text-white">{v.tileRisks}</span>
      </article>

      <article role="listitem" class="flex items-center gap-4 rounded-3xl bg-emerald-300/10 p-5 ring-1 ring-emerald-200/20 sm:col-span-2">
        <span class="grid h-11 w-11 shrink-0 place-items-center rounded-2xl bg-emerald-300/15 text-emerald-100" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M13 3 4 14h6l-1 7 9-11h-6l1-7z" />
          </svg>
        </span>
        <span class="text-base font-black tracking-tight text-white">{v.tileNextAction}</span>
      </article>
    </div>
  </div>
</aside>
