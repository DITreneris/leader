---
import SectionHeader from "./SectionHeader.astro";
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const modules = uiCopy[lang].modules;
---

<section id="context" class="section-y mx-auto max-w-7xl px-5 sm:px-8" aria-labelledby="context-title">
  <SectionHeader eyebrow={modules.eyebrow} title={modules.title} subtitle={modules.subtitle} titleId="context-title" />

  <div class="mx-auto mt-10 flex max-w-6xl flex-col gap-5">
    <div class="glass-card radius-xl overflow-hidden p-6 sm:p-8">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
        <p class="type-eyebrow-inline text-brand-accent-hover">{modules.context.title}</p>
        <span class="type-micro-label rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-slate-200">
          {modules.context.badge}
        </span>
      </div>
      <p class="mt-3 text-sm leading-6 text-slate-300">{modules.context.subtitle}</p>

      <div class="mt-6 grid gap-4 sm:grid-cols-2">
        <div>
          <label class="type-form-label text-slate-500" for="ctx-company">
            {modules.context.companyLabel}
          </label>
          <input
            id="ctx-company"
            name="ctx-company"
            type="text"
            placeholder={modules.context.companyPlaceholder}
            class="focus-ring mt-2 w-full rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3 text-sm font-semibold text-slate-100 placeholder:text-slate-600"
            data-context-field="company"
            autocomplete="organization"
          />
        </div>

        <div>
          <label class="type-form-label text-slate-500" for="ctx-goal">
            {modules.context.goalLabel}
          </label>
          <input
            id="ctx-goal"
            name="ctx-goal"
            type="text"
            placeholder={modules.context.goalPlaceholder}
            class="focus-ring mt-2 w-full rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3 text-sm font-semibold text-slate-100 placeholder:text-slate-600"
            data-context-field="goal"
            autocomplete="off"
          />
        </div>

        <div>
          <label class="type-form-label text-slate-500" for="ctx-constraint">
            {modules.context.constraintLabel}
          </label>
          <input
            id="ctx-constraint"
            name="ctx-constraint"
            type="text"
            placeholder={modules.context.constraintPlaceholder}
            class="focus-ring mt-2 w-full rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3 text-sm font-semibold text-slate-100 placeholder:text-slate-600"
            data-context-field="constraint"
            autocomplete="off"
          />
        </div>

        <div>
          <label class="type-form-label text-slate-500" for="ctx-bottleneck">
            {modules.context.bottleneckLabel}
          </label>
          <input
            id="ctx-bottleneck"
            name="ctx-bottleneck"
            type="text"
            placeholder={modules.context.bottleneckPlaceholder}
            class="focus-ring mt-2 w-full rounded-2xl border border-white/10 bg-slate-950/40 px-4 py-3 text-sm font-semibold text-slate-100 placeholder:text-slate-600"
            data-context-field="bottleneck"
            autocomplete="off"
          />
        </div>
      </div>

      <details class="surface-panel radius-lg mt-6 p-5">
        <summary class="focus-ring summary-hover -m-2 rounded-2xl px-2 py-2 text-xs font-semibold tracking-[0.18em] text-slate-300">
          {modules.rulesPreview.title}
        </summary>
        <ul class="mt-4 space-y-2 text-sm leading-6 text-slate-200">
          {modules.rulesPreview.items.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </details>

      <p class="mt-4 text-xs leading-5 text-slate-400" data-context-warning>
        {modules.contextWarning}
      </p>
    </div>

    <p class="radius-md border border-brand-accent/20 bg-brand-accent/10 px-5 py-4 text-sm font-semibold text-brand-accent-hover">
      {modules.startHere}
    </p>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {modules.items.map((m) => (
        <article class="surface-card radius-xl flex h-full flex-col overflow-hidden p-6" data-module-card data-module-id={m.id}>
          <div class="flex-1">
            <p class="type-eyebrow-inline text-brand-accent">{m.eyebrow}</p>
            <h3 class="mt-3 text-xl font-black text-white">{m.title}</h3>
            <p class="mt-2 text-sm leading-6 text-slate-300">{m.subtitle}</p>

            <div class="surface-panel radius-lg mt-5 p-4">
              <p class="type-micro-label text-slate-500">{modules.taskLabel}</p>
              <p class="mt-2 whitespace-pre-wrap font-mono text-sm leading-6 text-slate-200">{m.taskFormat}</p>
            </div>

            <details class="surface-panel radius-lg mt-4 p-4">
              <summary class="focus-ring summary-hover -m-2 rounded-2xl px-2 py-2 type-micro-label text-slate-400">
                {modules.outputLabel}
              </summary>
              <pre class="mt-3 max-h-40 overflow-auto whitespace-pre-wrap font-mono text-xs leading-5 text-slate-200 [tab-size:2]" tabindex="0">{m.outputExampleJson}</pre>
            </details>
          </div>

          <button
            type="button"
            class="focus-ring btn-outline-accent elevate-hover mt-5 rounded-full px-4 py-3 text-sm font-bold"
            data-module-copy={m.id}
            data-copy-label-i18n="modules.copyButton"
            data-copy-copied-i18n="modules.copiedButton"
          >
            {modules.copyButton}
          </button>
        </article>
      ))}
    </div>

    <article class="glass-card radius-xl flex h-full flex-col overflow-hidden p-6 sm:p-8" data-module-card data-module-id="custom">
      <div class="flex-1">
        <p class="type-eyebrow-inline text-brand-accent">{modules.custom.eyebrow}</p>
        <h3 class="mt-3 text-xl font-black text-white">{modules.custom.title}</h3>
        <p class="mt-2 text-sm leading-6 text-slate-300">{modules.custom.subtitle}</p>

        <div class="mt-5 grid gap-4 lg:grid-cols-2">
          <div>
            <label class="type-form-label text-slate-500" for="custom-task">
              {modules.custom.taskLabel}
            </label>
            <textarea
              id="custom-task"
              class="focus-ring mt-2 min-h-36 w-full rounded-3xl border border-white/10 bg-slate-950/40 px-4 py-3 font-mono text-sm leading-6 text-slate-100 placeholder:text-slate-600"
              placeholder={modules.custom.taskPlaceholder}
              data-custom-task
            ></textarea>
          </div>

          <div>
            <label class="type-form-label text-slate-500" for="custom-output">
              {modules.custom.outputLabel}
            </label>
            <textarea
              id="custom-output"
              class="focus-ring mt-2 min-h-36 w-full rounded-3xl border border-white/10 bg-slate-950/40 px-4 py-3 font-mono text-sm leading-6 text-slate-100 placeholder:text-slate-600"
              placeholder={modules.custom.outputPlaceholder}
              data-custom-output
            ></textarea>
          </div>
        </div>

        <p class="mt-3 text-sm font-semibold text-rose-100 hidden" data-custom-error role="status" aria-live="polite"></p>
      </div>

      <button
        type="button"
        class="focus-ring cta-gradient type-cta-label elevate-hover mt-5 rounded-full px-5 py-4 text-center text-slate-950 transition hover:brightness-110"
        data-custom-copy
        data-copy-label-i18n="modules.custom.copyButton"
        data-copy-copied-i18n="modules.custom.copiedButton"
      >
        {modules.custom.copyButton}
      </button>
    </article>
  </div>
</section>

