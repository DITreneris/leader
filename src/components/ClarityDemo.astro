---
const scenarioKeys = ["meeting", "report", "decision", "delegation", "communication"];
---

<section id="demo" class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-bold uppercase tracking-[0.28em] text-cyan-200" data-i18n="demo.eyebrow">Interactive static demo</p>
    <h2 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl" data-i18n="demo.title">Try one executive workflow.</h2>
    <p class="mt-5 text-lg leading-8 text-slate-300" data-i18n="demo.subtitle">
      Select a real CEO situation. The page shows a simulated AI output that demonstrates the system without sending data to an API.
    </p>
  </div>

  <div class="mt-10 flex flex-wrap justify-center gap-3">
    {
      scenarioKeys.map((scenario) => (
        <button
          type="button"
          data-scenario={scenario}
          class="rounded-full border border-white/10 bg-white/5 px-5 py-3 text-sm font-bold text-slate-200 transition hover:border-cyan-200/60 hover:text-white data-[active=true]:border-cyan-200 data-[active=true]:bg-cyan-300 data-[active=true]:text-slate-950"
        >
          {scenario}
        </button>
      ))
    }
  </div>

  <div class="mt-8 grid gap-5 lg:grid-cols-[0.9fr_1.1fr]">
    <div class="glass-card rounded-[2rem] p-6">
      <p class="text-sm font-bold uppercase tracking-[0.22em] text-slate-400" data-i18n="demo.messyInputLabel">Messy input</p>
      <p class="mt-5 min-h-48 rounded-3xl border border-white/10 bg-slate-950/70 p-5 text-lg leading-8 text-slate-200" data-demo-field="input">
        Tomorrow we have a leadership meeting about Q3 delays, sales forecast changes, and hiring freeze concerns. Notes are scattered across emails and Slack.
      </p>
    </div>

    <div class="glass-card rounded-[2rem] p-6">
      <div class="flex flex-col gap-4 border-b border-white/10 pb-5 sm:flex-row sm:items-center sm:justify-between">
        <p class="text-sm font-bold uppercase tracking-[0.22em] text-cyan-200" data-i18n="demo.outputLabel">Executive clarity output</p>
        <button type="button" data-copy-prompt class="rounded-full border border-cyan-200/40 px-4 py-2 text-sm font-bold text-cyan-100 transition hover:bg-cyan-300 hover:text-slate-950">
          Copy sample prompt
        </button>
      </div>

      <div class="mt-6 grid gap-4">
        <article class="rounded-3xl bg-cyan-300/10 p-5">
          <p class="text-sm font-bold text-cyan-100" data-i18n="demo.insight">Key insight</p>
          <p class="mt-2 text-slate-100" data-demo-field="insight">The meeting is not about status. It needs one priority decision.</p>
        </article>
        <article class="rounded-3xl bg-white/[0.06] p-5">
          <p class="text-sm font-bold text-slate-300" data-i18n="demo.decision">Decision needed</p>
          <p class="mt-2 text-slate-100" data-demo-field="decision">Choose which Q3 initiatives stay funded.</p>
        </article>
        <div class="grid gap-4 md:grid-cols-2">
          <article class="rounded-3xl bg-rose-300/10 p-5">
            <p class="text-sm font-bold text-rose-100" data-i18n="demo.risks">Top risks</p>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-rose-50" data-demo-risks></ul>
          </article>
          <article class="rounded-3xl bg-amber-300/10 p-5">
            <p class="text-sm font-bold text-amber-100" data-i18n="demo.questions">Questions to ask</p>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-amber-50" data-demo-questions></ul>
          </article>
        </div>
        <article class="rounded-3xl bg-emerald-300/10 p-5">
          <p class="text-sm font-bold text-emerald-100" data-i18n="demo.action">Next action</p>
          <p class="mt-2 text-emerald-50" data-demo-field="action">Open the meeting with the trade-off.</p>
        </article>
      </div>
    </div>
  </div>
</section>
