---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const demo = uiCopy[lang].demo;
const scenarioKeys = ["meeting", "report", "decision", "delegation", "communication"] as const;
const defaultScenario = demo.scenarios.meeting;
---

<section id="demo" class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-semibold tracking-[0.18em] text-brand-accent">
      {demo.eyebrow}
    </p>
    <h2 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl">
      {demo.title}
    </h2>
    <p class="mt-5 text-lg leading-8 text-slate-300">
      {demo.subtitle}
    </p>
  </div>

  <div class="mx-auto mt-10 flex max-w-4xl flex-wrap justify-center gap-3">
    {
      scenarioKeys.map((scenario, index) => (
        <button
          type="button"
          data-scenario={scenario}
          data-active={index === 0 ? "true" : "false"}
          class="focus-ring btn-chip elevate-hover min-h-11 rounded-full px-5 py-3 text-sm font-bold"
        >
          {demo.scenarios[scenario].label}
        </button>
      ))
    }
  </div>

  <div class="mx-auto mt-8 max-w-3xl">
    <article
      class="glass-card rounded-[2rem] p-6 sm:p-8"
      aria-live="polite"
      aria-atomic="true"
    >
      <p class="text-[10px] font-black uppercase tracking-[0.22em] text-brand-accent-hover">
        {demo.briefLabel}
      </p>
      <div class="mt-5 grid gap-4">
        <div class="surface-accent accent-glow rounded-3xl p-5 ring-1 ring-brand-accent/30">
          <p class="text-[10px] font-black uppercase tracking-[0.22em] text-brand-accent-hover">
            {demo.decision}
          </p>
          <p class="mt-2 text-base font-semibold leading-7 text-white sm:text-lg" data-demo-field="decision">
            {defaultScenario.decision}
          </p>
        </div>
        <div class="rounded-3xl bg-emerald-300/10 p-5 ring-1 ring-emerald-200/20">
          <p class="text-[10px] font-black uppercase tracking-[0.22em] text-emerald-100">
            {demo.action}
          </p>
          <p class="mt-2 text-base font-semibold leading-7 text-white sm:text-lg" data-demo-field="action">
            {defaultScenario.action}
          </p>
        </div>
        <div class="surface-muted rounded-3xl p-5">
          <p class="text-[10px] font-black uppercase tracking-[0.22em] text-slate-400">
            {demo.insight}
          </p>
          <p class="mt-2 text-sm leading-6 text-slate-200" data-demo-field="insight">
            {defaultScenario.insight}
          </p>
        </div>
      </div>
    </article>

    <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <button
        type="button"
        data-copy-prompt
        class="focus-ring cta-gradient elevate-hover rounded-full px-6 py-3 text-sm font-black uppercase tracking-[0.16em] text-slate-950 transition hover:brightness-110"
      >
        {demo.copyPrompt}
      </button>

      <details class="group rounded-3xl border border-white/10 bg-white/[0.03]">
        <summary class="focus-ring summary-hover flex cursor-pointer list-none items-center gap-2 rounded-3xl px-5 py-3 text-sm font-semibold text-slate-200 outline-none transition [&::-webkit-details-marker]:hidden">
          <span class="block group-open:hidden">{demo.showDetails}</span>
          <span class="hidden group-open:block">{demo.hideDetails}</span>
          <svg
            viewBox="0 0 16 16"
            width="14"
            height="14"
            aria-hidden="true"
            class="ml-1 transition group-open:rotate-180"
          >
            <path d="M3 6l5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none" />
          </svg>
        </summary>
        <div class="grid gap-4 border-t border-white/10 p-4 sm:p-5 md:grid-cols-2">
          <div class="rounded-2xl bg-rose-300/10 p-4 ring-1 ring-rose-200/15">
            <p class="text-[10px] font-black uppercase tracking-[0.22em] text-rose-100">
              {demo.risks}
            </p>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-rose-50" data-demo-risks>
              {defaultScenario.risks.map((risk) => (
                <li>{risk}</li>
              ))}
            </ul>
          </div>
          <div class="rounded-2xl bg-amber-300/10 p-4 ring-1 ring-amber-200/15">
            <p class="text-[10px] font-black uppercase tracking-[0.22em] text-amber-100">
              {demo.questions}
            </p>
            <ul class="mt-3 list-disc space-y-2 pl-5 text-sm leading-6 text-amber-50" data-demo-questions>
              {defaultScenario.questions.map((question) => (
                <li>{question}</li>
              ))}
            </ul>
          </div>
        </div>
      </details>

      <details class="group rounded-3xl border border-white/10 bg-white/[0.03]">
        <summary class="focus-ring summary-hover flex cursor-pointer list-none items-center gap-2 rounded-3xl px-5 py-3 text-sm font-semibold text-slate-200 outline-none transition [&::-webkit-details-marker]:hidden">
          <span class="block group-open:hidden">{demo.showInput}</span>
          <span class="hidden group-open:block">{demo.hideInput}</span>
          <svg
            viewBox="0 0 16 16"
            width="14"
            height="14"
            aria-hidden="true"
            class="ml-1 transition group-open:rotate-180"
          >
            <path d="M3 6l5 5 5-5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" fill="none" />
          </svg>
        </summary>
        <div class="border-t border-white/10 p-4 sm:p-5">
          <p class="text-[10px] font-black uppercase tracking-[0.22em] text-slate-500">
            {demo.messyInputLabel}
          </p>
          <p class="mt-3 text-sm leading-6 text-slate-200" data-demo-field="input">
            {defaultScenario.input}
          </p>
        </div>
      </details>
    </div>

    <pre
      class="sr-only"
      data-demo-field="prompt"
      tabindex="-1"
      aria-hidden="true"
    >{defaultScenario.prompt}</pre>
  </div>

  <div class="mx-auto mt-12 max-w-4xl rounded-[1.75rem] border border-brand-accent/25 bg-brand-accent/[0.07] px-6 py-6 text-center sm:text-left">
    <p class="text-xs font-semibold tracking-[0.18em] text-brand-accent-hover">
      {demo.followUpEyebrow}
    </p>
    <div class="mt-2 flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm leading-6 text-slate-200 sm:text-base sm:leading-7">
        {demo.followUpText}
      </p>
      <a
        href="#kit"
        class="focus-ring cta-gradient elevate-hover shrink-0 rounded-full px-5 py-3 text-center text-sm font-black uppercase tracking-[0.16em] text-slate-950 transition hover:brightness-110"
      >
        {demo.followUpCta}
      </a>
    </div>
  </div>
</section>
