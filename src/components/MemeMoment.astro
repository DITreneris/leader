---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

type AccentTone = "gold" | "amber" | "fuchsia" | "emerald" | "rose";

type Props = {
  lang: Language;
  index: number;
  src: string;
  alt: string;
  accent?: AccentTone;
  width: number;
  height: number;
  loading?: "lazy" | "eager";
  fetchPriority?: "high" | "low" | "auto";
};

const {
  lang,
  index,
  src,
  alt,
  accent = "gold",
  width,
  height,
  loading = "lazy",
  fetchPriority,
} = Astro.props;

const page = uiCopy[lang];
const [memeTitle, memeBody] = page.memes.items[index];

const accentMap: Record<AccentTone, { wrap: string; glow: string; rule: string }> = {
  gold: {
    wrap: "border-brand-accent/30 from-brand-accent/15",
    glow: "bg-brand-accent/20",
    rule: "from-transparent via-brand-accent/40 to-transparent",
  },
  amber: {
    wrap: "border-amber-300/30 from-amber-500/15",
    glow: "bg-amber-300/20",
    rule: "from-transparent via-amber-300/40 to-transparent",
  },
  fuchsia: {
    wrap: "border-fuchsia-300/30 from-fuchsia-500/15",
    glow: "bg-fuchsia-300/20",
    rule: "from-transparent via-fuchsia-300/40 to-transparent",
  },
  emerald: {
    wrap: "border-emerald-300/30 from-emerald-500/15",
    glow: "bg-emerald-300/20",
    rule: "from-transparent via-emerald-300/40 to-transparent",
  },
  rose: {
    wrap: "border-rose-300/30 from-rose-500/15",
    glow: "bg-rose-300/20",
    rule: "from-transparent via-rose-300/40 to-transparent",
  },
};

const tone = accentMap[accent];
const baseUrl = import.meta.env.BASE_URL;
const imageUrl = `${baseUrl}assets/memes/${src}`.replace(/([^:]\/)\/+/g, "$1");
---

<aside
  class="section-y-tight relative mx-auto max-w-7xl px-5 sm:px-8"
  aria-label={page.memes.sectionAriaLabel}
>
  <div class={`pointer-events-none absolute inset-x-10 top-0 h-px bg-gradient-to-r ${tone.rule}`}></div>
  <div class="flex flex-col gap-6 lg:gap-8">
    <figure
      class={`radius-meme-outer group relative w-full overflow-hidden border bg-gradient-to-br via-slate-950/60 to-slate-950/80 p-2 sm:p-3 ${tone.wrap}`}
    >
      <div class={`pointer-events-none absolute -inset-10 rounded-full blur-3xl ${tone.glow}`}></div>
      <!-- 16:9 frame; object-contain so nothing is cropped (exports are widescreen memes). -->
      <div class="relative aspect-video w-full overflow-hidden bg-slate-950/60 radius-meme-inner">
        <img
          src={imageUrl}
          alt={alt}
          loading={loading}
          decoding="async"
          width={width}
          height={height}
          fetchpriority={fetchPriority}
          class="h-full w-full object-contain object-center transition duration-500 motion-safe:group-hover:scale-[1.015]"
        />
      </div>
    </figure>
    <div class="mx-auto flex max-w-3xl flex-col gap-3 text-center sm:max-w-4xl">
      <h3 class="text-2xl font-black tracking-tight text-white sm:text-3xl lg:text-4xl xl:text-5xl">
        {memeTitle}
      </h3>
      <p class="text-base leading-7 text-slate-300 sm:text-lg lg:text-xl lg:leading-8">
        {memeBody}
      </p>
    </div>
  </div>
</aside>
