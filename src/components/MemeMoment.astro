---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

type AccentTone = "gold" | "amber" | "fuchsia" | "emerald" | "rose";

type Props = {
  lang: Language;
  index: number;
  src: string;
  alt: string;
  side?: "left" | "right";
  accent?: AccentTone;
  width: number;
  height: number;
};

const {
  lang,
  index,
  src,
  alt,
  side = "left",
  accent = "gold",
  width,
  height,
} = Astro.props;

const page = uiCopy[lang];
const [memeTitle, memeBody] = page.memes.items[index];

const accentMap: Record<AccentTone, { wrap: string; glow: string; eyebrow: string; rule: string }> = {
  gold: {
    wrap: "border-brand-accent/30 from-brand-accent/15",
    glow: "bg-brand-accent/20",
    eyebrow: "text-brand-accent-hover",
    rule: "from-transparent via-brand-accent/40 to-transparent",
  },
  amber: {
    wrap: "border-amber-300/30 from-amber-500/15",
    glow: "bg-amber-300/20",
    eyebrow: "text-amber-200",
    rule: "from-transparent via-amber-300/40 to-transparent",
  },
  fuchsia: {
    wrap: "border-fuchsia-300/30 from-fuchsia-500/15",
    glow: "bg-fuchsia-300/20",
    eyebrow: "text-fuchsia-200",
    rule: "from-transparent via-fuchsia-300/40 to-transparent",
  },
  emerald: {
    wrap: "border-emerald-300/30 from-emerald-500/15",
    glow: "bg-emerald-300/20",
    eyebrow: "text-emerald-200",
    rule: "from-transparent via-emerald-300/40 to-transparent",
  },
  rose: {
    wrap: "border-rose-300/30 from-rose-500/15",
    glow: "bg-rose-300/20",
    eyebrow: "text-rose-200",
    rule: "from-transparent via-rose-300/40 to-transparent",
  },
};

const tone = accentMap[accent];
const isRight = side === "right";
const baseUrl = import.meta.env.BASE_URL;
const imageUrl = `${baseUrl}assets/memes/${src}`.replace(/([^:]\/)\/+/g, "$1");
const orderClass = isRight ? "lg:[&>figure]:order-2" : "";
---

<aside class="relative mx-auto max-w-7xl px-5 py-14 sm:px-8 sm:py-16" aria-label="Executive recognition moment">
  <div class={`pointer-events-none absolute inset-x-10 top-0 h-px bg-gradient-to-r ${tone.rule}`}></div>
  <div class={`grid gap-8 lg:grid-cols-[minmax(0,1.25fr)_minmax(0,0.75fr)] lg:items-center ${orderClass}`}>
    <figure
      class={`group relative overflow-hidden rounded-[2.25rem] border bg-gradient-to-br via-slate-950/60 to-slate-950/80 p-3 ${tone.wrap}`}
    >
      <div class={`pointer-events-none absolute -inset-10 rounded-full blur-3xl ${tone.glow}`}></div>
      <img
        src={imageUrl}
        alt={alt}
        loading="lazy"
        decoding="async"
        width={width}
        height={height}
        class="relative block h-auto w-full rounded-[2rem] object-cover transition duration-500 motion-safe:group-hover:scale-[1.015]"
      />
    </figure>
    <div class="flex flex-col gap-3">
      <span class={`text-xs font-bold uppercase tracking-[0.32em] ${tone.eyebrow}`}>
        {page.memes.eyebrow}
      </span>
      <h3 class="text-2xl font-black tracking-tight text-white sm:text-3xl lg:text-4xl">
        {memeTitle}
      </h3>
      <p class="text-base leading-7 text-slate-300 sm:text-lg">
        {memeBody}
      </p>
    </div>
  </div>
</aside>
