---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const anatomy = uiCopy[lang].anatomy;
---

<section class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
  <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-center">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.28em] text-brand-accent">
        {anatomy.eyebrow}
      </p>
      <h2 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl">
        {anatomy.title}
      </h2>
      <p class="mt-5 text-lg leading-8 text-slate-300">
        {anatomy.subtitle}
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2">
      {
        anatomy.items.map(([title, body], index) => (
          <article class="glass-card rounded-[1.75rem] p-6">
            <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-2xl bg-brand-accent/15 text-sm font-black text-brand-accent-hover">
              0{index + 1}
            </div>
            <h3 class="text-xl font-black text-white">{title}</h3>
            <p class="mt-3 text-sm leading-6 text-slate-300">{body}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
