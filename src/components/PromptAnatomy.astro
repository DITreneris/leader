---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const anatomy = uiCopy[lang].anatomy;
---

<section id="anatomy" class="section-y mx-auto max-w-7xl px-5 sm:px-8" aria-labelledby="anatomy-heading">
  <details class="group glass-card radius-xl overflow-hidden border border-white/10 open:border-brand-accent/25">
    <summary class="focus-ring summary-hover cursor-pointer list-none p-6 outline-none sm:p-8 [&::-webkit-details-marker]:hidden">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <p class="type-section-eyebrow">{anatomy.eyebrow}</p>
          <h2 id="anatomy-heading" class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl">
            {anatomy.title}
          </h2>
          <p class="mt-3 text-sm font-semibold text-brand-accent-hover/90 sm:text-base">
            {anatomy.expandSummary}
          </p>
          <p class="mt-4 text-lg leading-8 text-slate-300">
            {anatomy.subtitle}
          </p>
        </div>
        <span
          aria-hidden="true"
          class="mt-1 flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-xl font-black text-brand-accent transition motion-safe:group-open:rotate-45 group-open:border-brand-accent/40 group-open:bg-brand-accent/15"
        >
          +
        </span>
      </div>
    </summary>

    <div class="border-t border-white/10 p-6 sm:p-8 sm:pt-6">
      <div class="grid gap-4 sm:grid-cols-2">
        {
          anatomy.items.map(([title, body], index) => (
            <article class="surface-panel radius-lg p-6">
              <p class="type-eyebrow-inline text-slate-400">
                {anatomy.stepPrefix} {index + 1}
              </p>
              <h3 class="text-xl font-black text-white">{title}</h3>
              <p class="mt-3 text-sm leading-6 text-slate-300">{body}</p>
            </article>
          ))
        }
      </div>
    </div>
  </details>
</section>
