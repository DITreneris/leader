---
const items = [0, 1, 2, 3, 4];
---

<section class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
  <div class="mb-10 max-w-3xl">
    <p class="text-sm font-bold uppercase tracking-[0.28em] text-cyan-200" data-i18n="workflows.eyebrow">CEO use cases</p>
    <h2 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl" data-i18n="workflows.title">Five places where leaders lose time.</h2>
  </div>

  <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-5">
    {
      items.map((index) => (
        <article class="glass-card rounded-[1.75rem] p-5 transition hover:-translate-y-1 hover:border-cyan-200/40">
          <div class="mb-8 flex h-11 w-11 items-center justify-center rounded-2xl bg-cyan-300/15 text-sm font-black text-cyan-100">
            0{index + 1}
          </div>
          <h3 class="text-xl font-black text-white" data-i18n={`workflows.items.${index}.0`}>Meetings</h3>
          <p class="mt-4 text-sm leading-6 text-slate-300" data-i18n={`workflows.items.${index}.1`}>
            Turn scattered notes into decisions, risks, and agenda focus.
          </p>
        </article>
      ))
    }
  </div>
</section>
