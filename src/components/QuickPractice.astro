---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const qp = uiCopy[lang].quickPractice;
---

<section id="practice" class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-bold uppercase tracking-[0.28em] text-brand-accent">
      {qp.eyebrow}
    </p>
    <h2 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl">
      {qp.title}
    </h2>
    <p class="mt-5 text-lg font-semibold leading-8 text-slate-200">
      {qp.subtitleLead}
    </p>
    <p class="mt-3 text-base leading-7 text-slate-300">
      {qp.subtitleTrail}
    </p>
  </div>

  <ol class="mt-10 grid list-none gap-5 lg:grid-cols-2 lg:items-stretch">
    <li class="rounded-[2rem] border border-rose-200/15 bg-rose-950/20 p-6">
      <p class="text-sm font-bold uppercase tracking-[0.22em] text-rose-200">
        {qp.beforeTitle}
      </p>
      <p class="mt-5 rounded-3xl bg-black/20 p-5 text-xl font-semibold text-white">
        {qp.beforeText}
      </p>
      <p class="mt-5 text-sm font-bold uppercase tracking-[0.2em] text-rose-100">
        {qp.beforeLabel}
      </p>
      <ul class="mt-4 space-y-2 text-sm leading-6 text-rose-100">
        {qp.beforeBullets.map((bullet) => (
          <li>{bullet}</li>
        ))}
      </ul>
    </li>

    <li class="glass-card rounded-[2rem] p-6">
      <p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-accent">
        {qp.afterTitle}
      </p>
      <p class="mt-3 text-sm leading-6 text-slate-300">
        {qp.structureHelper}
      </p>

      <div class="mt-5 flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
        <div class="min-w-0 flex-1">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-slate-500">{qp.promptBlockLabel}</p>
          <div class="surface-panel relative mt-2 overflow-hidden rounded-2xl">
            <pre
              class="max-h-32 overflow-hidden p-4 text-left font-mono text-sm leading-6 text-slate-200 whitespace-pre-wrap [tab-size:2]"
              tabindex="0"
              data-qp-full-prompt
            >
{qp.prompt}</pre
            >
            <div class="pointer-events-none absolute inset-x-0 bottom-0 h-14 bg-gradient-to-b from-transparent via-slate-950/60 to-slate-950/95"></div>
          </div>
          <p class="mt-3 text-xs leading-5 text-slate-300">{qp.previewHint}</p>
        </div>
        <button
          type="button"
          data-copy-i18n="quickPractice.prompt"
          data-copy-label-i18n="quickPractice.copyPrompt"
          data-copy-copied-i18n="quickPractice.copied"
          class="focus-ring btn-outline-accent elevate-hover h-fit w-full shrink-0 rounded-full px-4 py-3 text-sm font-bold sm:mt-6 sm:w-auto sm:self-start"
        >
          {qp.copyPrompt}
        </button>
      </div>

      <p class="mt-6 text-sm font-bold uppercase tracking-[0.2em] text-brand-accent-hover">
        {qp.afterLabel}
      </p>
      <ul class="mt-4 space-y-2 text-sm leading-6 text-[#f4d27a]">
        {qp.afterBullets.map((bullet) => (
          <li>{bullet}</li>
        ))}
      </ul>
    </li>

    <li class="rounded-[2rem] border border-emerald-200/25 bg-emerald-950/20 p-7 ring-1 ring-emerald-200/10">
      <p class="text-sm font-bold uppercase tracking-[0.22em] text-emerald-200">
        {qp.resultTitle}
      </p>
      <p class="mt-2 text-xs font-medium uppercase tracking-wider text-emerald-200/70">
        {qp.resultMicro}
      </p>
      <p class="mt-4 rounded-3xl bg-emerald-300/10 p-6 text-xl font-semibold leading-9 text-emerald-50">
        {qp.resultText}
      </p>
    </li>

    <li class="rounded-[2rem] border border-amber-200/20 bg-amber-950/20 p-6">
      <p class="text-sm font-bold uppercase tracking-[0.22em] text-amber-200">
        {qp.checkTitle}
      </p>
      <p class="mt-5 rounded-3xl bg-amber-300/10 p-5 text-lg font-semibold leading-8 text-amber-50">
        {qp.checkText}
      </p>
      <p class="mt-4 text-xs leading-5 text-amber-200/70">
        {qp.checkBridge}
      </p>
    </li>
  </ol>

  <div class="mx-auto mt-10 flex max-w-4xl flex-col gap-4 rounded-[1.75rem] border border-brand-accent/25 bg-brand-accent/[0.07] px-6 py-6 text-center sm:text-left">
    <p class="text-sm font-bold text-slate-100">{qp.ctaText}</p>
    <div class="flex flex-col items-stretch gap-3 sm:flex-row sm:items-center sm:justify-between">
      <a
        href={qp.ctaDemoHref}
        class="focus-ring cta-gradient rounded-full px-5 py-3 text-center text-sm font-black uppercase tracking-[0.18em] text-slate-950 transition hover:brightness-110"
      >
        {qp.ctaDemo}
      </a>
      <a
        href={qp.ctaHref}
        target="_blank"
        rel="noreferrer"
        class="focus-ring rounded-full border border-white/20 px-5 py-3 text-center text-sm font-bold uppercase tracking-[0.16em] text-white transition hover:border-brand-accent-hover/50 hover:bg-white/5"
      >
        {qp.ctaLabel}
      </a>
    </div>
    <p class="text-center text-xs text-slate-500 sm:text-left">
      <a href="#safety-check" class="focus-ring font-semibold text-amber-200/90 underline decoration-amber-200/30 underline-offset-2 hover:text-amber-100">
        {qp.safetyAnchorLabel} →
      </a>
    </p>
  </div>
</section>
