---
import { buildPromptAnatomyUrl } from "../constants/outboundLinks";
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const cta = uiCopy[lang].cta;
const downloadHref = `${import.meta.env.BASE_URL}assets/downloads/executive-operating-kit.pdf`.replace(/([^:]\/)\/+/g, "$1");
const promptAnatomySecondaryHref = buildPromptAnatomyUrl({
  medium: "lead_magnet",
  campaign: "executive_prompt_library",
});
---

<section id="kit" tabindex="-1" class="section-y mx-auto max-w-7xl px-5 sm:px-8">
  <div class="cta-gradient elevate-hover radius-xl relative overflow-hidden border border-brand-accent-hover/40 p-8 text-slate-950 sm:p-12">
    <div class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-white/50 blur-3xl"></div>
    <div class="relative max-w-3xl">
      <p class="text-sm font-black uppercase tracking-[0.2em]">{cta.eyebrow}</p>
      <h2 class="mt-4 text-4xl font-black tracking-tight sm:text-5xl">
        {cta.title}
      </h2>
      <p class="mt-5 text-lg leading-8 text-slate-800">
        {cta.subtitle}
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href={downloadHref}
          download="PromptAnatomy-Max-Value-Kit.pdf"
          data-kit-download
          class="focus-ring type-cta-label elevate-hover rounded-full bg-slate-950 px-6 py-4 text-center text-white transition hover:bg-slate-800"
        >
          {cta.primary}
        </a>
        <a
          href={promptAnatomySecondaryHref}
          target="_blank"
          rel="noopener noreferrer"
          class="focus-ring type-cta-label elevate-hover rounded-full border border-slate-950/20 px-6 py-4 text-center text-slate-950 transition hover:bg-white/40"
        >
          {cta.secondary}
        </a>
      </div>
    </div>
  </div>
</section>
