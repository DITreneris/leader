---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const cta = uiCopy[lang].cta;
const downloadHref = `${import.meta.env.BASE_URL}assets/downloads/executive-operating-kit.pdf`.replace(/([^:]\/)\/+/g, "$1");
---

<section id="kit" class="mx-auto max-w-7xl px-5 pb-16 pt-20 sm:px-8">
  <div class="cta-gradient elevate-hover relative overflow-hidden rounded-[2rem] border border-brand-accent-hover/40 p-8 text-slate-950 sm:p-12">
    <div class="absolute -right-24 -top-24 h-72 w-72 rounded-full bg-white/50 blur-3xl"></div>
    <div class="relative max-w-3xl">
      <p class="text-sm font-black uppercase tracking-[0.28em]">{cta.eyebrow}</p>
      <h2 class="mt-4 text-4xl font-black tracking-tight sm:text-5xl">
        {cta.title}
      </h2>
      <p class="mt-5 text-lg leading-8 text-slate-800">
        {cta.subtitle}
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href={downloadHref}
          download
          data-kit-download
          class="focus-ring elevate-hover rounded-full bg-slate-950 px-6 py-4 text-center text-sm font-black uppercase tracking-[0.18em] text-white transition hover:bg-slate-800"
        >
          {cta.primary}
        </a>
        <a
          href="https://www.promptanatomy.app/?utm_source=leader&utm_medium=lead_magnet&utm_campaign=executive_prompt_library"
          class="focus-ring elevate-hover rounded-full border border-slate-950/20 px-6 py-4 text-center text-sm font-black uppercase tracking-[0.18em] text-slate-950 transition hover:bg-white/40"
        >
          {cta.secondary}
        </a>
      </div>
    </div>
  </div>
</section>
