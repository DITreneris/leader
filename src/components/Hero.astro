---
import LanguageToggle from "./LanguageToggle.astro";
import FlowScheme from "./FlowScheme.astro";
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const c = uiCopy[lang];
const promptAnatomyHref = "https://www.promptanatomy.app/?utm_source=leader&utm_medium=hero&utm_campaign=secondary";
---

<div class="relative z-50 mx-auto max-w-7xl px-5 sm:px-8">
<header class="flex items-center justify-between gap-4 py-6">
  <a href="#" class="focus-ring group flex items-center gap-3" aria-label="Prompt Anatomy Executive OS">
    <span class="logo-tile logo-glow flex h-10 w-10 items-center justify-center rounded-2xl ring-1 ring-white/10">
      <svg viewBox="0 0 32 32" aria-hidden="true" class="h-6 w-6">
        <path
          fill="#fbd304"
          transform="translate(4 3)"
          d="M13.5 1.5 4.5 14.25h6L8.25 22.5 19.5 9.75h-6L13.5 1.5z"
        />
      </svg>
    </span>
    <span class="flex flex-col leading-tight">
      <span class="flex items-baseline gap-2">
        <span class="text-base font-black tracking-tight text-white sm:text-lg">Prompt Anatomy</span>
        <span class="rounded-full bg-brand-accent/15 px-2 py-0.5 text-[10px] font-black uppercase tracking-[0.2em] text-brand-accent-hover">
          Executive OS
        </span>
      </span>
      <span class="text-[10px] font-semibold uppercase tracking-[0.28em] text-slate-500"> Kit v1.0 · CEO/COO </span>
    </span>
  </a>

  <nav class="hidden items-center gap-6 text-sm font-medium text-slate-300 lg:flex lg:gap-8" aria-label="Primary">
    <a href="#practice" class="focus-ring transition hover:text-white">{c.nav.practice}</a>
    <a href="#demo" class="focus-ring transition hover:text-white">{c.nav.proof}</a>
    <a href="#system" class="focus-ring transition hover:text-white">{c.nav.system}</a>
    <a href="#library" class="focus-ring transition hover:text-white">{c.nav.library}</a>
    <a href="#kit" class="focus-ring transition hover:text-white">{c.nav.kitPdf}</a>
  </nav>

  <div class="flex items-center gap-3">
    <button
      type="button"
      class="focus-ring inline-flex h-11 w-11 items-center justify-center rounded-xl border border-white/15 bg-white/5 text-white md:hidden"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Open menu"
      data-mobile-menu-button
    >
      <span aria-hidden="true" class="flex flex-col gap-1.5">
        <span class="block h-0.5 w-5 rounded-full bg-white"></span>
        <span class="block h-0.5 w-5 rounded-full bg-white"></span>
        <span class="block h-0.5 w-5 rounded-full bg-white"></span>
      </span>
    </button>
    <LanguageToggle />
  </div>
</header>

  <div
    id="mobile-menu"
    class="absolute right-0 top-full z-40 mt-2 hidden w-[min(100vw-2.5rem,20rem)] rounded-2xl border border-white/10 bg-slate-950/95 p-4 shadow-2xl backdrop-blur-xl md:hidden"
    data-mobile-menu-panel
  >
    <nav class="flex flex-col gap-2 text-sm font-medium text-slate-200" aria-label="Mobile primary">
      <a href="#practice" class="focus-ring rounded-xl px-3 py-3 transition hover:bg-white/5" data-mobile-menu-link>
        {c.nav.practice}
      </a>
      <a href="#demo" class="focus-ring rounded-xl px-3 py-3 transition hover:bg-white/5" data-mobile-menu-link>
        {c.nav.proof}
      </a>
      <a href="#system" class="focus-ring rounded-xl px-3 py-3 transition hover:bg-white/5" data-mobile-menu-link>
        {c.nav.system}
      </a>
      <a href="#library" class="focus-ring rounded-xl px-3 py-3 transition hover:bg-white/5" data-mobile-menu-link>
        {c.nav.library}
      </a>
      <a href="#kit" class="focus-ring rounded-xl px-3 py-3 transition hover:bg-white/5" data-mobile-menu-link>
        {c.nav.kitPdf}
      </a>
      <a
        href={promptAnatomyHref}
        target="_blank"
        rel="noreferrer"
        class="focus-ring mt-2 rounded-full border border-white/20 px-4 py-3 text-center text-xs font-black uppercase tracking-[0.14em] text-white transition hover:bg-white/5"
        data-mobile-menu-link
      >
        {c.hero.secondaryCta}
      </a>
    </nav>
  </div>
</div>

<section class="relative mx-auto grid max-w-7xl gap-10 px-5 pb-20 pt-10 sm:px-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-center lg:pb-28 lg:pt-16">
  <div class="relative z-10">
    <p class="mb-5 inline-flex rounded-full border border-brand-accent/30 bg-brand-accent/15 px-4 py-2 text-sm font-semibold text-brand-accent-hover">
      {c.hero.eyebrow}
    </p>
    <h1 class="max-w-4xl text-5xl font-black tracking-tight text-white sm:text-6xl lg:text-7xl">
      {c.hero.title}
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-8 text-slate-300 sm:text-xl">
      {c.hero.subtitle}
    </p>
    <div class="mt-9 flex flex-col gap-3 sm:flex-row">
      <a
        href="#practice"
        class="focus-ring cta-gradient rounded-full px-6 py-4 text-center text-sm font-black uppercase tracking-[0.18em] text-slate-950 transition hover:brightness-110"
      >
        {c.hero.primaryCta}
      </a>
      <a
        href={promptAnatomyHref}
        target="_blank"
        rel="noreferrer"
        class="focus-ring rounded-full border border-white/15 px-6 py-4 text-center text-sm font-bold uppercase tracking-[0.18em] text-white transition hover:border-brand-accent-hover/70 hover:bg-white/5"
      >
        {c.hero.secondaryCta}
      </a>
    </div>
    <p class="mt-5 text-center text-sm text-slate-500 sm:text-left">
      <a href="#practice" class="focus-ring font-semibold text-brand-accent-hover/90 underline decoration-brand-accent/40 decoration-1 underline-offset-4 transition hover:text-brand-accent">
        {c.flowScheme.nextStepHint}
      </a>
    </p>
  </div>

  <FlowScheme lang={lang} />
</section>

<script>
  const btn = document.querySelector<HTMLButtonElement>("[data-mobile-menu-button]");
  const panel = document.querySelector<HTMLElement>("[data-mobile-menu-panel]");
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-mobile-menu-link]");

  const isExpanded = () => btn?.getAttribute("aria-expanded") === "true";

  const close = () => {
    if (!panel || !btn) return;
    panel.classList.add("hidden");
    btn.setAttribute("aria-expanded", "false");
    btn.focus({ preventScroll: true });
  };

  const open = () => {
    if (!panel || !btn) return;
    panel.classList.remove("hidden");
    btn.setAttribute("aria-expanded", "true");
    panel.querySelector<HTMLElement>("[data-mobile-menu-link]")?.focus({ preventScroll: true });
  };

  const toggle = () => {
    if (!panel || !btn) return;
    const expanded = isExpanded();
    if (expanded) close();
    else open();
  };

  btn?.addEventListener("click", toggle);

  links.forEach((a) => a.addEventListener("click", close));

  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") close();
  });

  document.addEventListener("pointerdown", (e) => {
    if (!panel || !btn || !isExpanded()) return;
    const target = e.target as Node | null;
    if (!target) return;
    if (panel.contains(target)) return;
    if (btn.contains(target)) return;
    close();
  });

  window.addEventListener(
    "scroll",
    () => {
      if (!isExpanded()) return;
      close();
    },
    { passive: true }
  );

  window.addEventListener("hashchange", () => {
    if (!isExpanded()) return;
    close();
  });
</script>
