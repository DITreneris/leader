---
interface Props {
  compact?: boolean;
  /** Accessible name for the EN/LT toggle group (localized). */
  groupAriaLabel?: string;
}

const { compact = false, groupAriaLabel = "Language" } = Astro.props;

const pathname = Astro.url.pathname;
const p = pathname.endsWith("/") ? pathname : `${pathname}/`;
const base = import.meta.env.BASE_URL;

let enHref: string;
let ltHref: string;

if (p.includes("/lt/")) {
  ltHref = p;
  enHref = p.replace("/lt/", "/en/");
} else if (p.includes("/en/")) {
  enHref = p;
  ltHref = p.replace("/en/", "/lt/");
} else {
  enHref = `${base}en/`.replace(/([^:]\/)\/+/g, "$1");
  ltHref = `${base}lt/`.replace(/([^:]\/)\/+/g, "$1");
}

const isEn = p.includes("/en/");
const isLt = p.includes("/lt/");

const btn = compact
  ? "min-h-8 min-w-8 px-2 text-[10px] font-bold uppercase tracking-wider"
  : "min-h-11 min-w-11 px-3 text-xs font-black uppercase tracking-[0.18em]";
const wrap = compact ? "p-0.5 gap-0.5" : "p-1 gap-1";
---

<div
  class={`flex items-center rounded-full border border-white/10 bg-white/5 ${wrap}`}
  role="group"
  aria-label={groupAriaLabel}
>
  <a
    href={enHref}
    lang="en"
    aria-current={isEn ? "page" : undefined}
    class={`focus-ring flex items-center justify-center rounded-full transition hover:text-white ${btn} ${isEn ? "bg-brand-accent text-slate-950" : "text-slate-300"}`}
  >
    EN
  </a>
  <a
    href={ltHref}
    lang="lt"
    aria-current={isLt ? "page" : undefined}
    class={`focus-ring flex items-center justify-center rounded-full transition hover:text-white ${btn} ${isLt ? "bg-brand-accent text-slate-950" : "text-slate-300"}`}
  >
    LT
  </a>
</div>
