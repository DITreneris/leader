---
const pathname = Astro.url.pathname;
const p = pathname.endsWith("/") ? pathname : `${pathname}/`;
const base = import.meta.env.BASE_URL;

let enHref: string;
let ltHref: string;

if (p.includes("/lt/")) {
  ltHref = p;
  enHref = p.replace("/lt/", "/en/");
} else if (p.includes("/en/")) {
  enHref = p;
  ltHref = p.replace("/en/", "/lt/");
} else {
  enHref = `${base}en/`.replace(/([^:]\/)\/+/g, "$1");
  ltHref = `${base}lt/`.replace(/([^:]\/)\/+/g, "$1");
}

const isEn = p.includes("/en/");
const isLt = p.includes("/lt/");
---

<div class="flex items-center gap-1 rounded-full border border-white/10 bg-white/5 p-1" role="group" aria-label="Language">
  <a
    href={enHref}
    lang="en"
    aria-current={isEn ? "page" : undefined}
    class={`focus-ring flex min-h-11 min-w-11 items-center justify-center rounded-full px-3 text-xs font-black uppercase tracking-[0.18em] transition hover:text-white ${isEn ? "bg-brand-accent text-slate-950" : "text-slate-300"}`
    }
  >
    EN
  </a>
  <a
    href={ltHref}
    lang="lt"
    aria-current={isLt ? "page" : undefined}
    class={`focus-ring flex min-h-11 min-w-11 items-center justify-center rounded-full px-3 text-xs font-black uppercase tracking-[0.18em] transition hover:text-white ${isLt ? "bg-brand-accent text-slate-950" : "text-slate-300"}`
    }
  >
    LT
  </a>
</div>
