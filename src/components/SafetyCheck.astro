---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const safety = uiCopy[lang].safety;

/** Fixed scan-row icons (facts → risk → context → owner); order matches `safety.items`. */
const checkIcons = ["✓", "⚠", "?", "👤"] as const;
---

<section
  id="safety-check"
  class="section-y section-y-roomy-lg mx-auto max-w-7xl border-t border-white/5 px-5 sm:px-8"
  aria-labelledby="safety-check-title"
>
  <div class="grid gap-10 lg:grid-cols-[minmax(0,7fr)_minmax(0,3fr)] lg:items-start lg:gap-12">
    <div>
      <p class="type-eyebrow-promo-bright text-amber-200/90 sm:text-sm">{safety.eyebrow}</p>
      <h2 id="safety-check-title" class="mt-4 text-3xl font-black tracking-tight text-white sm:text-4xl lg:text-[2.75rem] lg:leading-[1.08]">
        {safety.title}
      </h2>
      <p class="mt-4 max-w-2xl text-base leading-relaxed text-slate-400 sm:text-lg sm:leading-7">
        {safety.subtitle}
      </p>

      <p class="type-form-label text-amber-200/80">{safety.promptBlockLabel}</p>
      <div
        class="surface-panel relative mt-3 rounded-2xl border border-amber-200/20 transition-shadow focus-within:shadow-[0_0_0_1px_rgba(251,191,36,0.25)]"
      >
        <pre
          class="max-h-[min(28rem,70vh)] overflow-y-auto p-6 text-left font-mono text-[15px] leading-relaxed text-amber-50/95 whitespace-pre-wrap [tab-size:2]"
          tabindex="0"
          data-safety-full-prompt
        >
          {safety.prompt}
        </pre>
      </div>

      <button
        type="button"
        data-copy-i18n="safety.prompt"
        data-copy-label-i18n="safety.copyPrompt"
        data-copy-copied-i18n="safety.copied"
        class="focus-ring type-cta-label elevate-hover mt-6 rounded-full border border-amber-200/50 px-5 py-3 text-amber-100 transition hover:bg-amber-300 hover:text-slate-950"
      >
        {safety.copyPrompt}
      </button>
      <p class="mt-4 text-xs leading-5 text-slate-500">{safety.previewHint}</p>
    </div>

    <aside class="lg:sticky lg:top-28" aria-label={safety.processLabel}>
      <p class="type-eyebrow-promo-bright text-amber-200/80">{safety.processLabel}</p>

      <div class="mt-4 flex flex-col gap-2">
        {
          safety.items.map(([scan, deep], index) => (
            <details class="group rounded-xl border border-white/[0.06] bg-white/[0.02]">
              <summary
                class="focus-ring flex cursor-pointer list-none items-start gap-3 rounded-xl px-4 py-3 text-left outline-none transition hover:bg-white/[0.04] [&::-webkit-details-marker]:hidden"
              >
                <span
                  class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-amber-300/10 text-sm text-amber-100/95"
                  aria-hidden="true"
                >
                  {checkIcons[index] ?? "•"}
                </span>
                <span class="text-[15px] font-semibold leading-snug text-white">{scan}</span>
                <svg
                  viewBox="0 0 16 16"
                  width="14"
                  height="14"
                  aria-hidden="true"
                  class="ml-auto mt-1 shrink-0 text-slate-500 transition group-open:rotate-180"
                >
                  <path
                    d="M3 6l5 5 5-5"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    fill="none"
                  />
                </svg>
              </summary>
              <p class="border-t border-white/[0.06] px-4 py-3 pl-[3.75rem] text-sm leading-relaxed text-slate-400">{deep}</p>
            </details>
          ))
        }
      </div>
    </aside>
  </div>
</section>
