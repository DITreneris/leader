---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const safety = uiCopy[lang].safety;
const lastItemIndex = safety.items.length - 1;
---

<section class="mx-auto max-w-7xl px-5 py-16 sm:px-8 lg:py-14">
  <div class="grid gap-8 lg:grid-cols-[0.78fr_1.22fr] lg:items-center">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.28em] text-amber-200">
        {safety.eyebrow}
      </p>
      <h2 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl">
        {safety.title}
      </h2>
      <p class="mt-5 text-lg leading-8 text-slate-300">
        {safety.subtitle}
      </p>
      <button
        type="button"
        data-copy-i18n="safety.prompt"
        data-copy-label-i18n="safety.copyPrompt"
        data-copy-copied-i18n="safety.copied"
        class="focus-ring elevate-hover mt-7 rounded-full border border-amber-200/50 px-5 py-3 text-sm font-black uppercase tracking-[0.16em] text-amber-100 transition hover:bg-amber-300 hover:text-slate-950"
      >
        {safety.copyPrompt}
      </button>
      <p class="mt-5 text-xs font-bold uppercase tracking-[0.2em] text-amber-200/80">{safety.promptBlockLabel}</p>
      <div class="surface-panel relative mt-2 overflow-hidden rounded-2xl border border-amber-200/20">
        <pre
          class="max-h-32 overflow-hidden p-4 text-left font-mono text-sm leading-6 text-amber-50/95 whitespace-pre-wrap [tab-size:2]"
          tabindex="0"
          data-safety-full-prompt
        >
          {safety.prompt}
        </pre>
        <div class="pointer-events-none absolute inset-x-0 bottom-0 h-14 bg-gradient-to-b from-transparent via-slate-950/60 to-slate-950/95"></div>
      </div>
      <p class="mt-3 text-xs leading-5 text-slate-300">{safety.previewHint}</p>
    </div>

    <div class="glass-card rounded-[2rem] p-6 sm:p-7">
      <p class="text-xs font-bold uppercase tracking-[0.28em] text-amber-200/80">{safety.processLabel}</p>

      <ol class="mt-5 space-y-4" aria-label={safety.processLabel}>
        {
          safety.items.map(([title, body], index) => (
            <li class:list={["relative", index !== lastItemIndex && "pb-4"]}>
              <article
                class:list={[
                  "surface-panel relative overflow-hidden rounded-[1.5rem] p-5 pl-16",
                  index === lastItemIndex && "border border-amber-200/15",
                ]}
              >
                <div class="absolute left-5 top-5 flex h-10 w-10 items-center justify-center rounded-2xl bg-amber-300/15 text-sm font-black text-amber-100">
                  0{index + 1}
                </div>
                {index !== lastItemIndex && (
                  <div class="pointer-events-none absolute left-9 top-[3.25rem] h-[calc(100%+1rem)] w-px bg-gradient-to-b from-amber-200/20 via-amber-200/10 to-transparent"></div>
                )}

                <h3 class="text-lg font-black text-white">{title}</h3>
                <p class="mt-3 text-sm leading-6 text-slate-300">{body}</p>
              </article>
            </li>
          ))
        }
      </ol>
    </div>
  </div>
</section>
