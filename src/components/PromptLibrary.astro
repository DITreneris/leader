---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const library = uiCopy[lang].library;
const downloadHref = `${import.meta.env.BASE_URL}assets/downloads/executive-operating-kit.pdf`.replace(/([^:]\/)\/+/g, "$1");
---

<section id="library" class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-bold uppercase tracking-[0.28em] text-brand-accent">
      {library.starter.eyebrow}
    </p>
    <h2 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl">
      {library.starter.title}
    </h2>
    <p class="mt-5 text-lg leading-8 text-slate-300">
      {library.starter.subtitle}
    </p>
  </div>

  <div class="mx-auto mt-10 max-w-4xl rounded-[1.75rem] border border-white/10 bg-slate-950/55 p-5 sm:p-6">
    <p class="text-center text-xs font-bold uppercase tracking-[0.28em] text-brand-accent">
      {library.starter.pickerEyebrow}
    </p>
    <p class="mx-auto mt-3 max-w-2xl text-center text-sm leading-6 text-slate-300">
      {library.starter.pickerHelp}
    </p>
    <div class="mt-5 flex flex-wrap justify-center gap-2">
      {
        library.categories.map((category, categoryIndex) => (
          <button
            type="button"
            data-workflow-pick={categoryIndex}
            class="focus-ring min-h-11 rounded-full border border-white/15 bg-white/5 px-4 py-3 text-sm font-semibold text-slate-200 transition hover:border-brand-accent/40 hover:text-white data-[active=true]:border-brand-accent data-[active=true]:bg-brand-accent/15 data-[active=true]:text-brand-accent-hover"
          >
            {category.title}
          </button>
        ))
      }
    </div>
  </div>

  <div class="mt-8 grid gap-4 lg:grid-cols-2">
    {
      library.categories.map((category, categoryIndex) => {
        const starter = category.prompts[0];
        const path = `library.categories.${categoryIndex}.prompts.0`;

        return (
          <article
            class="glass-card rounded-[1.75rem] p-5 transition data-[workflow-active=true]:border-brand-accent/60 data-[workflow-active=true]:shadow-[0_0_60px_rgba(207,167,58,0.22)]"
            data-workflow-card={categoryIndex}
          >
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div>
                <p class="text-xs font-bold uppercase tracking-[0.22em] text-brand-accent">{category.title}</p>
                <h3 class="mt-3 text-xl font-black text-white">{starter.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-300">{starter.outcome}</p>
              </div>
              <button
                type="button"
                data-copy-i18n={`${path}.prompt`}
                data-copy-label-i18n="library.copyPrompt"
                data-copy-copied-i18n="library.copied"
                class="focus-ring shrink-0 rounded-full border border-brand-accent/40 px-4 py-3 text-sm font-bold text-brand-accent-hover transition hover:bg-brand-accent hover:text-slate-950"
              >
                {library.copyPrompt}
              </button>
            </div>
          </article>
        );
      })
    }
  </div>

  <div class="mx-auto mt-8 flex max-w-3xl flex-col items-center gap-4 text-center">
    <p class="rounded-full border border-brand-accent/25 bg-brand-accent/15 px-5 py-3 text-sm font-bold text-brand-accent-hover">
      {library.starter.note}
    </p>
    <a
      href={downloadHref}
      download
      data-kit-download
      class="focus-ring cta-gradient rounded-full px-6 py-4 text-center text-sm font-black uppercase tracking-[0.18em] text-slate-950 transition hover:brightness-110"
    >
      {library.starter.downloadCta}
    </a>
  </div>

  <details class="mx-auto mt-14 max-w-6xl glass-card group overflow-hidden rounded-[2rem] transition open:bg-slate-950/55">
    <summary class="library-summary focus-ring cursor-pointer list-none rounded-[2rem] p-6 outline-none transition hover:bg-white/[0.04] focus-visible:bg-white/[0.04]">
      <div class="flex items-start justify-between gap-4">
        <div class="flex-1">
          <p class="text-sm font-bold uppercase tracking-[0.28em] text-brand-accent">{library.eyebrow}</p>
          <h2 class="mt-4 text-3xl font-black tracking-tight text-white sm:text-4xl">{library.title}</h2>
          <p class="mt-3 text-base leading-7 text-slate-300 sm:text-lg">{library.subtitle}</p>
        </div>
        <span
          aria-hidden="true"
          class="mt-1 flex h-11 w-11 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-xl font-black text-brand-accent transition motion-safe:group-open:rotate-45 group-open:border-brand-accent/40 group-open:bg-brand-accent/15"
        >
          +
        </span>
      </div>
    </summary>

    <div class="grid gap-5 border-t border-white/10 p-6 lg:grid-cols-2">
      {
        library.categories.map((category, categoryIndex) => (
          <details class="rounded-[1.75rem] border border-white/10 bg-slate-950/55 transition open:bg-slate-950/70">
            <summary class="focus-ring cursor-pointer list-none rounded-[1.75rem] p-5 outline-none transition hover:bg-white/[0.04] focus-visible:bg-white/[0.04]">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  <p class="text-sm font-bold uppercase tracking-[0.22em] text-brand-accent">0{categoryIndex + 1}</p>
                  <h3 class="mt-3 text-xl font-black text-white">{category.title}</h3>
                  <p class="mt-3 leading-7 text-slate-300">{category.description}</p>
                </div>
                <span
                  aria-hidden="true"
                  class="mt-1 flex h-10 w-10 shrink-0 items-center justify-center rounded-full border border-white/10 bg-white/5 text-lg font-black text-brand-accent transition motion-safe:group-open:rotate-45"
                >
                  +
                </span>
              </div>
            </summary>

            <div class="grid gap-4 border-t border-white/10 p-5">
              {category.prompts.map((promptItem, promptIndex) => {
                const path = `library.categories.${categoryIndex}.prompts.${promptIndex}`;

                return (
                  <div class="rounded-[1.5rem] border border-white/10 bg-slate-950/65 p-5">
                    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
                      <div>
                        <h4 class="text-lg font-black text-white">{promptItem.title}</h4>
                        <p class="mt-2 text-sm leading-6 text-slate-300">{promptItem.outcome}</p>
                      </div>
                      <button
                        type="button"
                        data-copy-i18n={`${path}.prompt`}
                        data-copy-label-i18n="library.copyPrompt"
                        data-copy-copied-i18n="library.copied"
                        class="focus-ring shrink-0 rounded-full border border-brand-accent/40 px-4 py-3 text-sm font-bold text-brand-accent-hover transition hover:bg-brand-accent hover:text-slate-950"
                      >
                        {library.copyPrompt}
                      </button>
                    </div>
                    <p class="mt-4 rounded-2xl bg-white/[0.06] p-4 text-sm leading-6 text-slate-200">{promptItem.prompt}</p>
                  </div>
                );
              })}
            </div>
          </details>
        ))
      }
    </div>
  </details>
</section>

<script>
  const pickerButtons = document.querySelectorAll<HTMLButtonElement>("[data-workflow-pick]");
  const workflowCards = document.querySelectorAll<HTMLElement>("[data-workflow-card]");

  const prefersReducedMotion = () =>
    typeof window !== "undefined" &&
    window.matchMedia?.("(prefers-reduced-motion: reduce)")?.matches === true;

  const shouldScrollToCard = (card: HTMLElement) => {
    const rect = card.getBoundingClientRect();
    const viewHeight = window.innerHeight || document.documentElement.clientHeight || 0;
    if (!viewHeight) return true;

    const margin = 80;
    const topVisible = rect.top >= margin;
    const bottomVisible = rect.bottom <= viewHeight - margin;
    return !(topVisible && bottomVisible);
  };

  const scrollToCard = (card: HTMLElement) => {
    if (!shouldScrollToCard(card)) return;
    const behavior: ScrollBehavior = prefersReducedMotion() ? "auto" : "smooth";
    const block: ScrollLogicalPosition = window.innerWidth < 640 ? "start" : "center";
    card.scrollIntoView({ behavior, block });
  };

  const setActive = (categoryKey: string) => {
    pickerButtons.forEach((button) => {
      const isActive = button.dataset.workflowPick === categoryKey;
      button.dataset.active = String(isActive);
      button.setAttribute("aria-pressed", String(isActive));
    });

    workflowCards.forEach((card) => {
      const isActive = card.dataset.workflowCard === categoryKey;
      card.dataset.workflowActive = String(isActive);
    });

    const targetCard = Array.from(workflowCards).find((card) => card.dataset.workflowCard === categoryKey);
    if (targetCard) {
      scrollToCard(targetCard);
    }
  };

  pickerButtons.forEach((button) => {
    button.addEventListener("click", () => {
      setActive(button.dataset.workflowPick || "");
    });
  });
</script>
