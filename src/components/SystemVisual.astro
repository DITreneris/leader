---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const systemVisual = uiCopy[lang].systemVisual;
---

<section id="system" class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
  <div class="grid gap-12 lg:grid-cols-[1fr_1.05fr] lg:items-center">
    <div>
      <p class="text-sm font-bold uppercase tracking-[0.28em] text-brand-accent">
        {systemVisual.eyebrow}
      </p>
      <h2 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl">
        {systemVisual.title}
      </h2>
      <p class="mt-5 text-base leading-7 text-slate-300 lg:text-lg">
        {systemVisual.flowCaption}
      </p>
    </div>

    <div class="relative">
      <div class="pointer-events-none absolute inset-0 rounded-[2rem] bg-gradient-to-br from-brand-accent/15 via-transparent to-slate-900/40 blur-2xl"></div>
      <div class="glass-card relative overflow-hidden rounded-[2rem] p-6 sm:p-8">
        <div class="space-y-6">
          {
            systemVisual.items.map(([title, body], index) => (
              <article class="relative flex gap-4">
                {index < systemVisual.items.length - 1 ? (
                  <div
                    class="absolute left-[1.35rem] top-11 h-[calc(100%+0.5rem)] w-px bg-gradient-to-b from-brand-accent/50 to-transparent"
                    aria-hidden="true"
                  />
                ) : null}
                <div class="relative z-10 flex h-11 w-11 shrink-0 items-center justify-center rounded-2xl bg-brand-accent/15 text-sm font-black text-brand-accent-hover">
                  0{index + 1}
                </div>
                <div>
                  <h3 class="text-lg font-black text-white">{title}</h3>
                  <p class="mt-3 text-sm leading-6 text-slate-300">{body}</p>
                </div>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
