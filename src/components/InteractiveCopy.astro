<script>
  type Scenario = {
    label: string;
    input: string;
    insight: string;
    decision: string;
    risks: readonly string[];
    questions: readonly string[];
    action: string;
    prompt: string;
  };

  type PageCopy = {
    demo: {
      copied: string;
      copyPrompt: string;
      scenarios: Record<string, Scenario>;
    };
    modules?: {
      roleLine?: string;
      jsonFirstRule?: string;
      missingContextRule?: string;
      explanationLabel?: string;
      rulesPreview?: { items?: readonly string[] };
      context?: {
        companyPlaceholder?: string;
        goalPlaceholder?: string;
        constraintPlaceholder?: string;
        bottleneckPlaceholder?: string;
      };
      items?: ReadonlyArray<{
        id: string;
        title: string;
        taskFormat: string;
        outputExampleJson: string;
      }>;
      custom?: {
        validationError?: string;
        copyButton?: string;
        copiedButton?: string;
      };
      copyButton?: string;
      copiedButton?: string;
    };
    a11y: { copyManual: string; skipLink?: string };
    [key: string]: unknown;
  };

  const copy = (window as unknown as { __PA_COPY__: PageCopy }).__PA_COPY__;

  const getValue = (path: string) => {
    return path.split(".").reduce<unknown>((current, part) => {
      if (current && typeof current === "object" && part in current) {
        return (current as Record<string, unknown>)[part];
      }
      return "";
    }, copy);
  };

  const manualMessage = () => {
    const m = getValue("a11y.copyManual");
    return typeof m === "string" && m ? m : "Select the prompt text, then copy (Ctrl+C or ⌘+C).";
  };

  const showCopyHint = (message: string) => {
    const hint = document.querySelector<HTMLElement>("[data-copy-manual-hint]");
    if (!hint) return;
    hint.textContent = message;
    hint.classList.remove("hidden");
    window.setTimeout(() => {
      hint.textContent = "";
      hint.classList.add("hidden");
    }, 4500);
  };

  const tryFocusNearbyPre = (fromButton: HTMLElement) => {
    const pre = fromButton
      .closest("section, article")
      ?.querySelector<HTMLElement>("pre[tabindex=\"0\"]");
    pre?.focus();
  };

  const scenarioButtons = document.querySelectorAll<HTMLButtonElement>("[data-scenario]");
  const copyPromptButton = document.querySelector<HTMLButtonElement>("[data-copy-prompt]");
  const genericCopyButtons = document.querySelectorAll<HTMLButtonElement>("[data-copy-i18n]");
  const moduleCopyButtons = document.querySelectorAll<HTMLButtonElement>("[data-module-copy]");
  const customCopyButton = document.querySelector<HTMLButtonElement>("[data-custom-copy]");
  let activeScenario = "meeting";
  let copyHintTimeout = 0;

  const renderList = (selector: string, items: readonly string[]) => {
    const list = document.querySelector<HTMLElement>(selector);
    if (!list) return;

    const nodes = items.map((item) => {
      const listItem = document.createElement("li");
      listItem.textContent = item;
      return listItem;
    });
    list.replaceChildren(...nodes);
  };

  const renderScenario = () => {
    const scenario = copy.demo.scenarios[activeScenario];
    if (!scenario) return;

    document.querySelectorAll<HTMLElement>("[data-demo-field]").forEach((element) => {
      const key = element.dataset.demoField as keyof Scenario;
      const value = scenario[key];
      if (typeof value === "string") {
        element.textContent = value;
      }
    });

    renderList("[data-demo-risks]", scenario.risks);
    renderList("[data-demo-questions]", scenario.questions);

    scenarioButtons.forEach((button) => {
      const scenarioKey = button.dataset.scenario || "";
      const item = copy.demo.scenarios[scenarioKey];
      button.textContent = item?.label ?? scenarioKey;
      button.dataset.active = String(scenarioKey === activeScenario);
    });

    if (copyPromptButton) {
      copyPromptButton.textContent = copy.demo.copyPrompt;
      copyPromptButton.removeAttribute("data-copied");
    }
  };

  const resetGenericCopyButtons = () => {
    genericCopyButtons.forEach((button) => {
      const label = getValue(button.dataset.copyLabelI18n || "");
      if (typeof label === "string") {
        button.textContent = label;
      }
      button.removeAttribute("data-copied");
    });
  };

  const readContext = () => {
    const companyEl = document.querySelector<HTMLInputElement>("[data-context-field=\"company\"]");
    const goalEl = document.querySelector<HTMLInputElement>("[data-context-field=\"goal\"]");
    const constraintEl = document.querySelector<HTMLInputElement>("[data-context-field=\"constraint\"]");
    const bottleneckEl = document.querySelector<HTMLInputElement>("[data-context-field=\"bottleneck\"]");

    const company =
      (companyEl?.value ?? "").trim() || copy.modules?.context?.companyPlaceholder || "[size, industry]";
    const goal = (goalEl?.value ?? "").trim() || copy.modules?.context?.goalPlaceholder || "[objective]";
    const constraint =
      (constraintEl?.value ?? "").trim() || copy.modules?.context?.constraintPlaceholder || "[budget/time/risk]";
    const bottleneck =
      (bottleneckEl?.value ?? "").trim() || copy.modules?.context?.bottleneckPlaceholder || "[main bottleneck]";

    const anyFilled =
      Boolean((companyEl?.value ?? "").trim()) ||
      Boolean((goalEl?.value ?? "").trim()) ||
      Boolean((constraintEl?.value ?? "").trim()) ||
      Boolean((bottleneckEl?.value ?? "").trim());

    return { company, goal, constraint, bottleneck, anyFilled };
  };

  const buildRulesBlock = () => {
    const injected = copy.modules?.rulesPreview?.items ?? [];
    const baseRules = injected.filter((r): r is string => typeof r === "string" && r.trim().length > 0);
    const missingContextRule =
      typeof copy.modules?.missingContextRule === "string" ? copy.modules.missingContextRule : "";
    const jsonFirstRule = typeof copy.modules?.jsonFirstRule === "string" ? copy.modules.jsonFirstRule : "";

    const merged = [
      ...baseRules,
      ...(missingContextRule ? [missingContextRule] : []),
      ...(jsonFirstRule ? [jsonFirstRule] : []),
    ];

    const unique = Array.from(new Set(merged.map((r) => r.trim()).filter(Boolean)));
    if (unique.length === 0) return "";
    return unique.map((r) => `- ${r}`).join("\n");
  };

  const buildCompiledPrompt = (moduleId: string, taskFormat: string, outputExampleJson: string) => {
    const roleLine =
      typeof copy.modules?.roleLine === "string" && copy.modules.roleLine
        ? copy.modules.roleLine
        : "ROLE: Tier-1 CEO advisor (strategy + operator)";

    const { company, goal, constraint, bottleneck } = readContext();
    const rules = buildRulesBlock();
    const explanationLabel =
      typeof copy.modules?.explanationLabel === "string" && copy.modules.explanationLabel
        ? copy.modules.explanationLabel
        : "Explanation";

    return `${roleLine}

CONTEXT:
- Company: ${company}
- Goal: ${goal}
- Constraint: ${constraint}
- Bottleneck: ${bottleneck}

RULES:
${rules || "- No generic advice\n- Do not invent facts\n- Output must be actionable"}

TASK (${moduleId}):
${taskFormat}

OUTPUT:
Return output as plain text:
- Short bullets and labeled sections.
- Include owners + deadlines where possible.
- Keep it decision-grade (recommendation, risks, next actions).

${explanationLabel.toUpperCase()}:
≤120 words, only if needed.

EXPECTED_OUTPUT_SHAPE:
${outputExampleJson}`.trim();
  };

  const setButtonCopiedState = (button: HTMLButtonElement, copiedText: string, labelText: string) => {
    button.textContent = copiedText;
    button.dataset.copied = "true";
    window.setTimeout(() => {
      button.textContent = labelText;
      button.removeAttribute("data-copied");
    }, 1400);
  };

  scenarioButtons.forEach((button) => {
    button.addEventListener("click", () => {
      activeScenario = button.dataset.scenario || activeScenario;
      renderScenario();
    });
  });

  copyPromptButton?.addEventListener("click", async () => {
    const scenario = copy.demo.scenarios[activeScenario];
    const text = scenario?.prompt ?? "";
    if (!text) return;

    if (!navigator.clipboard?.writeText) {
      showCopyHint(manualMessage());
      document.querySelector<HTMLElement>("[data-demo-field=\"prompt\"]")?.focus();
      return;
    }

    try {
      await navigator.clipboard.writeText(text);
      copyPromptButton.textContent = copy.demo.copied;
      copyPromptButton.dataset.copied = "true";
      window.clearTimeout(copyHintTimeout);
      copyHintTimeout = window.setTimeout(() => {
        copyPromptButton.textContent = copy.demo.copyPrompt;
        copyPromptButton.removeAttribute("data-copied");
      }, 1400);
    } catch {
      showCopyHint(manualMessage());
      document.querySelector<HTMLElement>("[data-demo-field=\"prompt\"]")?.focus();
    }
  });

  genericCopyButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      const prompt = getValue(button.dataset.copyI18n || "");
      if (typeof prompt !== "string" || !prompt) return;

      const label = getValue(button.dataset.copyLabelI18n || "");
      const copiedLabel = getValue(button.dataset.copyCopiedI18n || "");

      if (!navigator.clipboard?.writeText) {
        showCopyHint(manualMessage());
        tryFocusNearbyPre(button);
        return;
      }

      try {
        await navigator.clipboard.writeText(prompt);
        button.textContent = typeof copiedLabel === "string" ? copiedLabel : "Copied";
        button.dataset.copied = "true";
        window.setTimeout(() => {
          button.textContent = typeof label === "string" ? label : "Copy";
          button.removeAttribute("data-copied");
        }, 1400);
      } catch {
        showCopyHint(manualMessage());
        tryFocusNearbyPre(button);
      }
    });
  });

  moduleCopyButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      const moduleId = button.dataset.moduleCopy || "";
      if (!moduleId) return;
      const modules = copy.modules?.items ?? [];
      const module = modules.find((m) => m.id === moduleId);
      if (!module) return;

      const compiled = buildCompiledPrompt(moduleId, module.taskFormat, module.outputExampleJson);
      const label = getValue(button.dataset.copyLabelI18n || "");
      const copiedLabel = getValue(button.dataset.copyCopiedI18n || "");
      const labelText = typeof label === "string" && label ? label : button.textContent || "Copy";
      const copiedText = typeof copiedLabel === "string" && copiedLabel ? copiedLabel : "Copied";

      if (!navigator.clipboard?.writeText) {
        showCopyHint(manualMessage());
        return;
      }

      try {
        await navigator.clipboard.writeText(compiled);
        setButtonCopiedState(button, copiedText, labelText);
      } catch {
        showCopyHint(manualMessage());
      }
    });
  });

  customCopyButton?.addEventListener("click", async () => {
    const taskEl = document.querySelector<HTMLTextAreaElement>("[data-custom-task]");
    const outputEl = document.querySelector<HTMLTextAreaElement>("[data-custom-output]");
    const errorEl = document.querySelector<HTMLElement>("[data-custom-error]");
    if (!taskEl || !outputEl) return;

    const task = (taskEl.value || "").trim();
    const output = (outputEl.value || "").trim();
    if (errorEl) {
      errorEl.textContent = "";
      errorEl.classList.add("hidden");
    }

    const compiled = buildCompiledPrompt("custom", task || "[Define task here]", output);
    const label = getValue(customCopyButton.dataset.copyLabelI18n || "");
    const copiedLabel = getValue(customCopyButton.dataset.copyCopiedI18n || "");
    const labelText = typeof label === "string" && label ? label : customCopyButton.textContent || "Copy";
    const copiedText = typeof copiedLabel === "string" && copiedLabel ? copiedLabel : "Copied";

    if (!navigator.clipboard?.writeText) {
      showCopyHint(manualMessage());
      return;
    }

    try {
      await navigator.clipboard.writeText(compiled);
      setButtonCopiedState(customCopyButton, copiedText, labelText);
    } catch {
      showCopyHint(manualMessage());
    }
  });

  renderScenario();
  resetGenericCopyButtons();
</script>

<script>
  (function kitPdfFallback() {
    document.querySelectorAll<HTMLAnchorElement>("a[data-kit-download]").forEach((a) => {
      const pdfHref = a.getAttribute("href");
      if (!pdfHref || !pdfHref.endsWith(".pdf")) return;
      const htmlHref = pdfHref.replace(/\.pdf$/i, ".html");
      fetch(pdfHref, { method: "HEAD" })
        .then((r) => {
          if (r.status === 404) {
            a.setAttribute("href", htmlHref);
            a.removeAttribute("download");
          }
        })
        .catch(() => {});
    });
  })();
</script>
