---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const b = uiCopy[lang].promoBanner;
const href = "https://www.promptanatomy.app/?utm_source=leader&utm_medium=modules&utm_campaign=handoff";
---

<section class="section-y-tight mx-auto max-w-7xl px-5 sm:px-8" aria-label={b.ariaLabel}>
  <div class="glass-card radius-xl relative overflow-hidden border border-brand-accent/25 p-7 sm:p-10">
    <div class="pointer-events-none absolute -right-24 -top-24 h-72 w-72 rounded-full bg-brand-accent/15 blur-3xl"></div>
    <div class="pointer-events-none absolute -bottom-24 -left-24 h-72 w-72 rounded-full bg-white/5 blur-3xl"></div>

    <div class="relative flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-2xl">
        <p class="type-eyebrow-promo-bright">{b.eyebrow}</p>
        <h2 class="mt-3 text-2xl font-black tracking-tight text-white sm:text-3xl">
          {b.title}
        </h2>
        <p class="mt-3 text-sm leading-7 text-slate-300 sm:text-base">
          {b.subtitle}
        </p>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row lg:shrink-0">
        <a
          href={href}
          target="_blank"
          rel="noreferrer"
          class="focus-ring cta-gradient type-cta-label elevate-hover rounded-full px-6 py-4 text-center text-slate-950 transition hover:brightness-110"
        >
          {b.primaryCta}
        </a>
        <a
          href="#demo"
          class="focus-ring elevate-hover rounded-full border border-white/15 bg-white/[0.02] px-6 py-4 text-center text-sm font-semibold normal-case tracking-wide text-white transition hover:bg-white/[0.05]"
        >
          {b.secondaryCta}
        </a>
      </div>
    </div>
  </div>
</section>

