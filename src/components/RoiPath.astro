---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const roiPath = uiCopy[lang].roiPath;
---

<section class="mx-auto max-w-7xl px-5 py-20 sm:px-8">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-bold uppercase tracking-[0.28em] text-brand-accent">
      {roiPath.eyebrow}
    </p>
    <h2 class="mt-4 text-4xl font-black tracking-tight text-white sm:text-5xl">
      {roiPath.title}
    </h2>
    <p class="mt-5 text-lg leading-8 text-slate-300">
      {roiPath.subtitle}
    </p>
  </div>

  <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
    {
      roiPath.steps.map(([time, title, body]) => (
        <article class="glass-card rounded-[1.75rem] p-6">
          <p class="text-3xl font-black text-brand-accent-hover">{time}</p>
          <h3 class="mt-4 text-xl font-black text-white">{title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-300">{body}</p>
        </article>
      ))
    }
  </div>

  <p class="mx-auto mt-8 max-w-3xl rounded-full border border-brand-accent/25 bg-brand-accent/15 px-5 py-4 text-center text-sm font-bold text-brand-accent-hover">
    {roiPath.total}
  </p>
</section>
