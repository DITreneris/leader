---
import { buildConsumerAiUrl } from "../../constants/outboundLinks";
import type { Language } from "../../content/copy";
import { uiCopy } from "../../content/copy";

interface Props {
  lang: Language;
  surface: "context" | "demo";
  /** Extra top margin: default works for #context; use "tight" under demo copy row */
  spacing?: "default" | "tight";
}

const { lang, surface, spacing = "default" } = Astro.props;
const p = uiCopy[lang].pasteIntoAssistant;

const topClass = spacing === "tight" ? "mt-5" : "mt-8 sm:mt-10";

const links = [
  { href: buildConsumerAiUrl({ surface, provider: "chatgpt" }), label: p.openChatgpt },
  { href: buildConsumerAiUrl({ surface, provider: "claude" }), label: p.openClaude },
  { href: buildConsumerAiUrl({ surface, provider: "gemini" }), label: p.openGemini },
] as const;
---

<div
  class:list={["mx-auto max-w-2xl rounded-2xl border border-white/[0.06] bg-white/[0.02] px-5 py-5 sm:px-6", topClass]}
  aria-label={p.ariaLabel}
>
  <p class="text-center text-sm leading-relaxed text-slate-300 sm:text-base">{p.lead}</p>

  <div class="mt-5 text-center">
    <p class="text-[0.65rem] font-semibold uppercase tracking-[0.18em] text-slate-500">{p.continueLabel}</p>
    <div class="mt-3 flex flex-col items-center gap-1 sm:flex-row sm:flex-wrap sm:justify-center sm:gap-x-0 sm:gap-y-2">
      {
        links.map(({ href, label }, i) => (
          <a
            href={href}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              "focus-ring rounded-lg px-4 py-2.5 text-center text-sm font-semibold text-slate-400 transition hover:text-white sm:py-2",
              i > 0 && "sm:border-l sm:border-white/10 sm:pl-6 sm:ml-6",
            ]}
          >
            {label}
          </a>
        ))
      }
    </div>
  </div>

  <p class="mx-auto mt-4 max-w-lg text-center text-xs leading-relaxed text-slate-600">{p.licenseNote}</p>
</div>
