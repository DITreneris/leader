---
interface Props {
  /** Screen reader description of the full flow. */
  ariaLabel: string;
  stepBuild: string;
  stepCopy: string;
  stepPaste: string;
  stepDecide: string;
  outputTitle: string;
  outputDetail: string;
}

const { ariaLabel, stepBuild, stepCopy, stepPaste, stepDecide, outputTitle, outputDetail } = Astro.props;

const badge =
  "mx-auto flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-brand-accent/12 text-xs font-black text-brand-accent-hover ring-1 ring-brand-accent/20";
---

<div class="w-full" role="img" aria-label={ariaLabel}>
  <!-- Pipeline sits on parent surface — no second card shell -->
  <div class="px-0 sm:px-2">
    <!-- Mobile: centered stack -->
    <div class="mx-auto max-w-sm sm:hidden">
      <div class="text-center">
        <span class:list={[badge, "mx-auto"]}>1</span>
        <p class="mt-2.5 text-base font-black tracking-tight text-white">{stepBuild}</p>
      </div>
      <div class="flex justify-center py-2 text-lg text-white/20" aria-hidden="true">↓</div>
      <div class="text-center">
        <span class:list={[badge, "mx-auto"]}>2</span>
        <p class="mt-2.5 text-base font-black tracking-tight text-white">{stepCopy}</p>
      </div>
      <div class="flex justify-center py-2 text-lg text-white/20" aria-hidden="true">↓</div>
      <div class="text-center">
        <span class:list={[badge, "mx-auto"]}>3</span>
        <p class="mt-2.5 text-base font-black tracking-tight text-white">{stepPaste}</p>
      </div>
      <div class="flex justify-center py-2 text-lg text-white/20" aria-hidden="true">↓</div>
      <div class="text-center">
        <span class:list={[badge, "mx-auto"]}>4</span>
        <p class="mt-2.5 text-base font-black tracking-tight text-white">{stepDecide}</p>
      </div>
    </div>

    <!-- Desktop: horizontal rail -->
    <div class="hidden items-start justify-between gap-2 sm:flex lg:gap-4">
      <div class="min-w-0 flex-1 text-center">
        <span class:list={[badge, "mx-auto"]}>1</span>
        <p class="mt-3 text-sm font-black leading-snug text-white lg:text-base">{stepBuild}</p>
      </div>
      <div class="flex shrink-0 items-center self-center pt-6 text-lg text-white/25 lg:pt-7 lg:text-xl" aria-hidden="true">
        →
      </div>
      <div class="min-w-0 flex-1 text-center">
        <span class:list={[badge, "mx-auto"]}>2</span>
        <p class="mt-3 text-sm font-black leading-snug text-white lg:text-base">{stepCopy}</p>
      </div>
      <div class="flex shrink-0 items-center self-center pt-6 text-lg text-white/25 lg:pt-7 lg:text-xl" aria-hidden="true">
        →
      </div>
      <div class="min-w-0 flex-1 text-center">
        <span class:list={[badge, "mx-auto"]}>3</span>
        <p class="mt-3 text-sm font-black leading-snug text-white lg:text-base">{stepPaste}</p>
      </div>
      <div class="flex shrink-0 items-center self-center pt-6 text-lg text-white/25 lg:pt-7 lg:text-xl" aria-hidden="true">
        →
      </div>
      <div class="min-w-0 flex-1 text-center">
        <span class:list={[badge, "mx-auto"]}>4</span>
        <p class="mt-3 text-sm font-black leading-snug text-white lg:text-base">{stepDecide}</p>
      </div>
    </div>

    <!-- Output: single soft accent destination -->
    <div class="mx-auto mt-10 max-w-2xl border-t border-white/[0.08] pt-10 text-center sm:mt-12 sm:pt-12">
      <div class="rounded-2xl bg-gradient-to-b from-brand-accent/[0.12] to-transparent px-6 py-6 sm:px-8 sm:py-7">
        <p class="type-micro-label text-brand-accent-hover">{outputTitle}</p>
        <p class="mt-2 text-xl font-black leading-snug tracking-tight text-white sm:text-2xl">{outputDetail}</p>
      </div>
    </div>
  </div>
</div>
