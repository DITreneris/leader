---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";
import FlowScheme from "./FlowScheme.astro";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const c = uiCopy[lang];
const a = c.heroArtifact;
---

<aside class="glass-card relative overflow-hidden rounded-[2rem] p-6 sm:p-8" aria-label={a.ariaLabel}>
  <div class="pointer-events-none absolute -right-20 -top-24 h-72 w-72 rounded-full bg-brand-accent/15 blur-3xl"></div>
  <div class="pointer-events-none absolute -bottom-24 -left-24 h-72 w-72 rounded-full bg-white/5 blur-3xl"></div>

  <div class="relative">
    <div class="flex flex-wrap items-center gap-2">
      <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-200">
        {a.headerChipOne}
      </span>
      <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1.5 text-[10px] font-semibold uppercase tracking-[0.18em] text-slate-200">
        {a.headerChipTwo}
      </span>
      <span class="rounded-full border border-brand-accent/30 bg-brand-accent/15 px-3 py-1.5 text-[10px] font-black uppercase tracking-[0.18em] text-brand-accent-hover">
        {a.headerChipThree}
      </span>
    </div>

    <h2 class="mt-6 text-2xl font-black leading-tight tracking-tight text-white sm:text-3xl">
      {a.title}
    </h2>
    <p class="mt-2 max-w-xl text-sm leading-6 text-slate-300 sm:text-base sm:leading-7">
      {a.subtitle}
    </p>

    <div class="mt-6 grid gap-4">
      <article class="surface-panel rounded-3xl p-5">
        <p class="text-[10px] font-black uppercase tracking-[0.22em] text-slate-500">{a.decisionLabel}</p>
        <p class="mt-3 text-base font-semibold leading-7 text-slate-100">
          {a.decisionValue}
        </p>
      </article>

      <div class="grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
        <article class="surface-panel rounded-3xl p-5">
          <p class="text-[10px] font-black uppercase tracking-[0.22em] text-slate-500">{a.criteriaLabel}</p>
          <ul class="mt-4 space-y-2 text-sm leading-6 text-slate-200">
            {a.criteriaItems.map((item) => (
              <li class="flex gap-3">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-accent" aria-hidden="true" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>

        <article class="rounded-3xl bg-rose-300/10 p-5 ring-1 ring-rose-200/10">
          <p class="text-[10px] font-black uppercase tracking-[0.22em] text-rose-100">{a.risksLabel}</p>
          <ul class="mt-4 space-y-2 text-sm leading-6 text-rose-50">
            {a.riskItems.map((item) => (
              <li class="flex gap-3">
                <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-rose-200" aria-hidden="true" />
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <article class="surface-muted rounded-3xl p-5">
          <p class="text-[10px] font-black uppercase tracking-[0.22em] text-slate-500">{a.ownerLabel}</p>
          <p class="mt-3 text-base font-semibold text-slate-100">{a.ownerValue}</p>
        </article>
        <article class="surface-muted rounded-3xl p-5">
          <p class="text-[10px] font-black uppercase tracking-[0.22em] text-slate-500">{a.deadlineLabel}</p>
          <p class="mt-3 text-base font-semibold text-slate-100">{a.deadlineValue}</p>
        </article>
      </div>

      <article class="surface-accent accent-glow rounded-3xl p-5">
        <p class="text-[10px] font-black uppercase tracking-[0.22em] text-brand-accent-hover">{a.nextActionLabel}</p>
        <p class="mt-3 text-base font-semibold leading-7 text-slate-100">{a.nextActionValue}</p>
      </article>
    </div>

    <p class="mt-5 text-xs leading-5 text-slate-400">{a.helper}</p>

    <details class="mt-7">
      <summary class="focus-ring summary-hover rounded-2xl px-4 py-3 text-sm font-semibold text-slate-200">
        {a.howItWorksSummary}
      </summary>
      <div class="mt-4">
        <FlowScheme lang={lang} />
      </div>
    </details>
  </div>
</aside>

