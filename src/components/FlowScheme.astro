---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const flow = uiCopy[lang].flowScheme;
---

<section
  class="glass-card radius-xl relative overflow-hidden p-6 sm:p-8"
  aria-label={flow.a11yLabel}
>
  <div class="pointer-events-none absolute inset-x-10 top-0 h-40 rounded-full bg-brand-accent/12 blur-3xl"></div>

  <div class="relative">
    <p class="type-eyebrow-promo-bright sm:text-sm">{flow.eyebrow}</p>

    <div class="mt-6 grid gap-5 sm:mt-8 lg:grid-cols-3 lg:gap-5">
      <!-- 1 Input -->
      <article
        class="flex flex-col rounded-2xl border border-white/10 bg-slate-950/50 p-5 ring-1 ring-white/[0.04] sm:p-6"
      >
        <span
          class="mb-3 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-white/[0.06] text-xs font-black text-brand-accent-hover"
          aria-hidden="true"
        >
          1
        </span>
        <p class="type-form-label text-slate-400 sm:text-sm">{flow.inputLabel}</p>
        <p class="mt-3 text-base font-semibold leading-snug text-white sm:text-lg">
          {lang === "lt" ? (
            <>
              <span class="text-slate-500">„</span>
              {flow.inputExample}
              <span class="text-slate-500">“</span>
            </>
          ) : (
            <>
              <span class="text-slate-500">“</span>
              {flow.inputExample}
              <span class="text-slate-500">”</span>
            </>
          )}
        </p>
      </article>

      <!-- 2 Structure -->
      <article
        class="flex flex-col rounded-2xl border border-brand-accent/35 bg-brand-accent/[0.07] p-5 ring-1 ring-brand-accent/20 sm:p-6"
      >
        <span
          class="mb-3 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-brand-accent/20 text-xs font-black text-brand-accent-hover"
          aria-hidden="true"
        >
          2
        </span>
        <p class="type-form-label text-brand-accent-hover sm:text-sm">{flow.middleLabel}</p>
        <p class="mt-4 font-mono text-xs font-bold uppercase tracking-widest text-brand-accent sm:text-sm">
          {flow.middleBadge}
        </p>
      </article>

      <!-- 3 Output -->
      <article
        class="flex flex-col rounded-2xl border-2 border-brand-accent/50 bg-slate-950/60 p-5 shadow-[0_0_40px_-12px_rgba(207,167,58,0.35)] sm:p-6"
      >
        <span
          class="mb-3 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-xl bg-brand-accent/15 text-xs font-black text-brand-accent-hover"
          aria-hidden="true"
        >
          3
        </span>
        <p class="type-form-label text-brand-accent-hover sm:text-sm">{flow.outputLabel}</p>
        <ul class="mt-4 space-y-3 text-sm leading-relaxed text-slate-100 sm:text-base">
          {
            flow.outputBullets.map((line) => (
              <li class="flex gap-3">
                <span
                  class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-brand-accent"
                  aria-hidden="true"
                />
                <span>{line}</span>
              </li>
            ))
          }
        </ul>
      </article>
    </div>

    <p class="mt-6 border-t border-white/10 pt-5 text-sm leading-relaxed text-slate-400">
      {flow.bridgeNote}
    </p>
  </div>
</section>
