---
const items = [0, 1, 2];
---

<section class="mx-auto max-w-7xl px-5 pb-12 sm:px-8">
  <div class="glass-card rounded-[2rem] p-6 sm:p-8">
    <div class="grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.28em] text-cyan-200" data-i18n="proof.eyebrow">
          Why this works
        </p>
        <h2 class="mt-4 text-3xl font-black tracking-tight text-white sm:text-4xl" data-i18n="proof.title">
          One useful executive output before any theory.
        </h2>
      </div>

      <div class="grid gap-4 md:grid-cols-3">
        {
          items.map((index) => (
            <article class="rounded-[1.5rem] border border-white/10 bg-slate-950/60 p-5">
              <h3 class="text-lg font-black text-white" data-i18n={`proof.items.${index}.0`}>
                Outcome first
              </h3>
              <p class="mt-3 text-sm leading-6 text-slate-300" data-i18n={`proof.items.${index}.1`}>
                The page shows clarity before teaching the method.
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </div>
</section>
