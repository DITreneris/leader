---
import type { Language } from "../content/copy";
import { uiCopy } from "../content/copy";

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const proof = uiCopy[lang].proof;
---

<section class="mx-auto max-w-7xl px-5 py-16 sm:px-8">
  <div class="mx-auto max-w-3xl text-center">
    <p class="text-sm font-bold uppercase tracking-[0.28em] text-brand-accent">
      {proof.eyebrow}
    </p>
    <h2 class="mt-4 text-3xl font-black tracking-tight text-white sm:text-4xl">
      {proof.title}
    </h2>
  </div>

  <div class="mt-10 grid gap-5 md:grid-cols-3">
    {
      proof.items.map(([title, body], index) => (
        <article class="glass-card rounded-[1.75rem] p-6">
          <div class="mb-4 flex h-10 w-10 items-center justify-center rounded-2xl bg-brand-accent/15 text-sm font-black text-brand-accent-hover">
            0{index + 1}
          </div>
          <h3 class="text-lg font-black text-white">{title}</h3>
          <p class="mt-3 text-sm leading-6 text-slate-300">{body}</p>
        </article>
      ))
    }
  </div>
</section>
